FROM docker.io/library/eclipse-temurin@sha256:03d8df1b21de34fd980bd121631ca969b30ba65978d5f47f3797d6da8a3fd9fd

ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git git-lfs libatomic1 ripgrep \
    && git lfs install --system \
    && rm -rf /var/lib/apt/lists/*
RUN useradd --create-home --shell /bin/bash agent
RUN git init --quiet /app \
    && git -C /app remote add origin https://github.com/sargunv/mobility-data-kt.git \
    && git -C /app fetch --quiet --depth=4 --filter=blob:none origin refs/pull/53/head \
    && git -C /app checkout --quiet --detach 541fc977a939501693a195057d0d1ce39188b522 \
    && git -C /app lfs pull \
    && git -C /app lfs fsck \
    && git -C /app remote remove origin \
    && git -C /app config user.name benchmark-base \
    && git -C /app config user.email benchmark@invalid \
    && mkdir -p /opt/gradle-cache /opt/konan-cache \
    && chown -R agent:agent /app /opt/gradle-cache /opt/konan-cache

WORKDIR /app
ENV HOME=/home/agent GRADLE_USER_HOME=/opt/gradle-cache KONAN_DATA_DIR=/opt/konan-cache
USER agent
RUN ./gradlew --no-daemon --stacktrace updateKotlinAbi updateLegacyAbi \
    && git diff --exit-code \
    && ./gradlew --no-daemon --stacktrace \
        jvmTest jsNodeTest wasmJsNodeTest linuxX64Test detekt checkKotlinAbi checkLegacyAbi \
    && test -z "$(git status --porcelain)"

ENV GRADLE_OPTS=-Dorg.gradle.daemon=false
