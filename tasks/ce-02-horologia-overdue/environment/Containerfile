FROM docker.io/library/golang@sha256:09fb8a652cf7a990b714c46a9f0f5fd2d5bc2222d995166b91907c1c05b7d0e8

RUN apt-get update \
    && apt-get install -y --no-install-recommends dbus-x11 gnome-keyring ripgrep \
    && rm -rf /var/lib/apt/lists/*
RUN useradd --create-home --shell /bin/bash agent
RUN git init --quiet /app \
    && git -C /app remote add origin https://github.com/sargunv/horologia.git \
    && git -C /app fetch --quiet --depth=1 --filter=blob:none origin 1e90747f596becdb06d8cd8729f9a3df7853cdac \
    && git -C /app checkout --quiet --detach FETCH_HEAD \
    && rm -rf /app/.git \
    && git -C /app init --quiet --initial-branch=main \
    && git -C /app config user.name benchmark-base \
    && git -C /app config user.email benchmark@invalid \
    && git -C /app add --all \
    && git -C /app commit --quiet -m 'benchmark base'

WORKDIR /app/server
RUN go mod download \
    && GOBIN=/usr/local/bin go install github.com/sqlc-dev/sqlc/cmd/sqlc@v1.30.0 \
    && go run github.com/sqlc-dev/sqlc/cmd/sqlc generate \
    && git -C /app diff --exit-code -- server/internal/database/gen \
    && go test ./internal/taskengine -run '^TestValidateOverdueActionRule$' -count=1 \
    && cd /app/api \
    && go mod download \
    && cd /app/cli \
    && go mod download \
    && chown -R agent:agent /app /go

ENV HOME=/home/agent
USER agent
RUN cd /app/server \
    && go run github.com/sqlc-dev/sqlc/cmd/sqlc generate \
    && git -C /app diff --exit-code -- server/internal/database/gen \
    && go test ./... \
    && cd /app/api \
    && go test ./... \
    && dbus-run-session -- bash -c 'eval "$(printf benchmark-keyring | gnome-keyring-daemon --unlock --components=secrets)"; cd /app/cli; go test ./...'

WORKDIR /app
ENV GOTOOLCHAIN=local GOPROXY=off
