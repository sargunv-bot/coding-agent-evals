{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "base": {
      "type": "object",
      "properties": { "from_ref": { "type": "boolean" } }
    }
  },
  "type": "object",
  "properties": {
    "all_object": {
      "allOf": [
        { "type": "object", "properties": { "alpha": { "type": "boolean" } } },
        { "type": "object", "properties": { "beta": { "enum": ["b"] } } }
      ]
    },
    "one_object": {
      "oneOf": [
        { "type": "object", "properties": { "left": { "type": "boolean" } } },
        { "type": "object", "properties": { "right": { "type": "boolean" } } }
      ]
    },
    "any_object": {
      "anyOf": [
        { "type": "object", "properties": { "north": { "type": "boolean" } } },
        { "type": "object", "properties": { "south": { "type": "boolean" } } }
      ]
    },
    "nested": {
      "type": "object",
      "properties": {
        "choice": { "anyOf": [{ "type": "boolean" }, { "type": "null" }] }
      }
    },
    "ref_object": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        { "type": "object", "properties": { "local": { "type": "boolean" } } }
      ]
    },
    "typed_nullable": { "type": ["boolean", "null"] },
    "deduplicated": {
      "anyOf": [
        { "enum": ["same", "left"] },
        { "enum": ["same", "right"] }
      ]
    },
    "cross_kind_deduplicated": {
      "anyOf": [
        { "const": "same" },
        { "enum": ["same", "other"] }
      ]
    },
    "decoy_sibling": { "enum": ["must-not-leak"] }
  }
}
