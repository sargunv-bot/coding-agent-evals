FROM docker.io/library/ubuntu@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90

ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git python3 python3-venv \
    && rm -rf /var/lib/apt/lists/*
RUN python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir pydantic==2.13.4 pyyaml==6.0.3
RUN useradd --create-home --shell /bin/bash agent
RUN git init --quiet /app \
    && git -C /app remote add origin https://github.com/maplibre/maplibre-native-ffi.git \
    && git -C /app fetch --quiet --depth=1 --filter=blob:none origin 4fa163923d35aae4099417206a7345b52c2fbdc2 \
    && git -C /app checkout --quiet --detach FETCH_HEAD \
    && rm -rf /app/.git \
    && git -C /app init --quiet --initial-branch=main \
    && git -C /app config user.name benchmark-base \
    && git -C /app config user.email benchmark@invalid \
    && git -C /app add --all \
    && git -C /app commit --quiet -m 'benchmark base' \
    && chown -R agent:agent /app

WORKDIR /app
USER agent
ENV HOME=/home/agent PATH=/opt/venv/bin:$PATH
