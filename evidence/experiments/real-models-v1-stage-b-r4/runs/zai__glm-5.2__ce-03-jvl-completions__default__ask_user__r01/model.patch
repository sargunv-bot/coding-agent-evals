+/// Compute a display string for a schema's `type`, joining the array form with
+/// `|` and appending `null` when the OpenAPI `nullable` keyword is set.
+fn schema_type_string(schema: &serde_json::Value) -> Option<String> {
+    let mut types = schema_types(schema);
+    if schema.get("nullable").and_then(|v| v.as_bool()) == Some(true)
+        && !types.iter().any(|t| t == "null")
+    {
+        types.push("null".to_string());
+    }
+    if types.is_empty() {
+        None
+    } else {
+        Some(types.join("|"))
+    }
+}
+
+/// Stable dedup key for a concrete enum/const value (its canonical JSON form).
+fn value_dedup_key(val: &serde_json::Value) -> String {
