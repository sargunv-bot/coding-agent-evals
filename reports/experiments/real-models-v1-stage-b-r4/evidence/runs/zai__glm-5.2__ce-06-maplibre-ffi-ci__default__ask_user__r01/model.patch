+++ b/.github/ci-targets.toml
@@ -0,0 +1,142 @@
+# CI target support policy — the single source of truth for the `variants` job
+# in .github/workflows/ci.yml. Each target maps a mise variant (and its
+# `.mise/config.<variant>.toml`) to a runner and the set of CI steps it runs.
+#
+# Regenerate the checked-in workflow with:
+#   mise run ci:generate
+# Drift is rejected by:
+#   mise run ci:check   (also run as part of `mise run ci:lint`)
+
+# A CI step. `key` is the matrix flag the step is gated on (`if: matrix.<key>`).
+# Every target gets a boolean column for each step.
+[[step]]
+key = "build_native"
+name = "Build native library"
+run = "mise run build"
+
+[[step]]
+key = "test_native"
+name = "Test native library"
+run = "mise run test"
+
+[[step]]
+key = "java_ffm"
+name = "Build Java FFM binding"
+run = "mise run //bindings/java-ffm:build"
+
+[[step]]
+key = "java_jni"
+name = "Build Java JNI binding"
+run = "mise run //bindings/java-jni:build"
+
+[[step]]
+key = "dotnet"
+name = "Test .NET binding"
+run = "mise run //bindings/dotnet:test"
+
+[[step]]
+key = "kotlin_native"
+name = "Test Kotlin/Native binding"
+run = "mise run //bindings/kotlin-native:build"
+comment = [
+  "linux-arm64: no Kotlin/Native host — https://youtrack.jetbrains.com/issue/KT-36871",
+  "windows: no MSVC target — https://youtrack.jetbrains.com/issue/SKIKO-446",
+]
+
+[[step]]
+key = "rust"
+name = "Test Rust binding"
+run = "mise run //bindings/rust:ci"
+
+[[step]]
+key = "swift"
+name = "Test Swift binding"
+run = "mise run //bindings/swift:test"
+
+[[step]]
+key = "zig"
+name = "Test Zig binding"
+run = "mise run //bindings/zig:ci"
+
+[[step]]
+key = "lwjgl"
+name = "Build LWJGL example"
+run = "mise run //examples/lwjgl-map:build"
+
+[[step]]
+key = "rust_example"
+name = "Test Rust example"
+run = "mise run //examples/rust-map:ci"
+
+[[step]]
+key = "swift_example"
+name = "Build Swift example"
+run = "mise run //examples/swift-map:build"
+
+[[step]]
+key = "zig_example"
+name = "Build Zig example"
+run = "mise run //examples/zig-map:build"
+
+[[step]]
+key = "zig_readback"
+name = "Run Zig readback example"
+run = "mise run //examples/zig-readback:run"
+
+# A CI target. Every target must run exactly one of `build_native`/`test_native`.
+# `variant` must have a matching `.mise/config.<variant>.toml`.
+
+[[target]]
+variant = "linux-arm64-egl"
+runner = "ubuntu-24.04-arm"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "rust", "zig", "rust_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "linux-arm64-vulkan"
+runner = "ubuntu-24.04-arm"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "rust", "zig", "lwjgl", "rust_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "linux-x64-egl"
+runner = "ubuntu-latest"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "kotlin_native", "rust", "zig", "rust_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "linux-x64-vulkan"
+runner = "ubuntu-latest"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "kotlin_native", "rust", "zig", "lwjgl", "rust_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "macos-arm64-metal"
+runner = "macos-latest"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "kotlin_native", "rust", "swift", "zig", "rust_example", "swift_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "macos-arm64-vulkan"
+runner = "macos-latest"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "kotlin_native", "rust", "swift", "zig", "lwjgl", "rust_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "macos-arm64-egl"
+runner = "macos-latest"
+steps = ["test_native", "zig", "zig_readback"]
+
+[[target]]
+variant = "ios-arm64-metal"
+runner = "macos-latest"
+steps = ["build_native"]
+
+[[target]]
+variant = "ios-simulator-arm64-metal"
+runner = "macos-latest"
+steps = ["build_native"]
+
+[[target]]
+variant = "windows-x64-vulkan"
+runner = "windows-2022"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "rust", "zig", "lwjgl", "rust_example", "zig_example", "zig_readback"]
+
+[[target]]
+variant = "windows-x64-wgl"
+runner = "windows-2022"
+steps = ["test_native", "java_ffm", "java_jni", "dotnet", "rust", "zig", "rust_example", "zig_example", "zig_readback"]
