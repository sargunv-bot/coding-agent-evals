diff --git a/server/internal/database/migrations/00009_overdue_action_nonrecurring.sql b/server/internal/database/migrations/00009_overdue_action_nonrecurring.sql
new file mode 100644
index 0000000000000000000000000000000000000000..29647bfd82ae488753aaa33664e442fa53d4640f
--- /dev/null
+++ b/server/internal/database/migrations/00009_overdue_action_nonrecurring.sql
@@ -0,0 +1,42 @@
+-- +goose Up
+
+-- The task-engine model allows set_status and clear_due_date overdue actions
+-- on any task with a due date, including one-off and on-dependency tasks.
+-- advance_recurrence is only meaningful for scheduled recurrence types, so it
+-- remains restricted to completion_based and fixed_non_accumulating.
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_recurring;
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_advance_requires_schedule CHECK (
+        overdue_action IS NULL
+        OR overdue_action != 'advance_recurrence'
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
+
+-- Include one-off and on-dependency tasks now that they may carry rules.
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL;
+
+-- +goose Down
+
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_advance_requires_schedule;
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
+
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL
+      AND recurrence_type NOT IN ('one_off', 'on_dependency');
