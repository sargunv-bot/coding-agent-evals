+/// Verify a GitHub artifact attestation for a downloaded file, transparently
+/// handling releases that attest each file *inside* an archive rather than the
+/// archive blob itself.
+///
+/// Verification is **fail-closed** at every step:
+///
+/// 1. The archive blob (`archive_path`) is verified first — exactly the
+///    pre-existing behavior. A successful verification (`Ok(true)`) is returned
+///    immediately, and so is any error *other than* "no attestations exist for
+///    this digest" ([`AttestationError::NoAttestations`]). In particular, if
+///    attestations exist for the archive but fail to verify, that failure is
+///    surfaced and the inner-file fallback never runs.
+/// 2. Only when the archive has `NoAttestations` *and* `archive_path` is a
+///    recognizable multi-file archive is it extracted to a temp directory. A
+///    single inner file is then probed:
+///    - If the probe is `NoAttestations`, there is no evidence the release uses
+///      inner-file attestations, so the original `NoAttestations` is returned
+///      and callers' existing SLSA/unavailable fallbacks run unchanged (this
+///      keeps the fallback to O(1) extra API calls and preserves the rate-limit
+///      guarantee this bridge exists to maintain).
+///    - Otherwise the release attests inner files, so **every** regular inner
+///      file is required to have its own valid attestation. Directories and
+///      symlinks are ignored; a nested archive is treated as an opaque regular
+///      file that must itself be attested (it is not recursively unpacked). If
+///      **any** regular inner file is unattested, or fails verification, the
+///      whole archive is rejected.
+/// 3. Extraction failures and single-file/compressed payloads (`.gz`, `.xz`,
+///    raw binaries) are not treated as archives here, so the original
+///    `NoAttestations` result is returned and callers' existing fallbacks run
+///    unchanged.
+///
+/// This preserves archive-level verification while safely accepting releases
+/// that only attest the files inside the archive.
+pub async fn verify_attestation_or_archive_contents(
+    archive_path: &Path,
+    owner: &str,
+    repo: &str,
+    expected_workflow: Option<&str>,
+    api_url: Option<&str>,
+) -> AttestationResult<bool> {
+    // Clone the borrowed args so the verifier closure (which returns a future
+    // borrowing only its owned captures) can be reused across every inner file.
+    let owner = owner.to_string();
+    let repo = repo.to_string();
+    let expected_workflow = expected_workflow.map(str::to_string);
+    let api_url = api_url.map(str::to_string);
+    verify_archive_aware_with_verifier(archive_path, |path: &Path| {
+        let path = path.to_path_buf();
+        let owner = owner.clone();
+        let repo = repo.clone();
+        let expected_workflow = expected_workflow.clone();
+        let api_url = api_url.clone();
+        async move {
+            verify_attestation(
+                &path,
+                &owner,
+                &repo,
+                expected_workflow.as_deref(),
+                api_url.as_deref(),
+            )
+            .await
+        }
+    })
+    .await
+}
+
+/// Archive-aware verification core, generic over the per-file verifier so the
+/// fail-closed ordering, archive detection, extraction, and probe-based
+/// "every inner file must be attested" policy are unit-testable without
+/// touching the network.
+///
+/// The verifier is called on the archive blob first; then, only on
+/// `NoAttestations` for a real archive, a single inner file is probed to detect
+/// whether the release attests inner files. If it does, every remaining inner
+/// file must verify (`Ok(true)`) for the archive to be accepted; otherwise the
+/// original `NoAttestations` is returned. See [`verify_attestation_or_archive_contents`]
+/// for the full policy.
+async fn verify_archive_aware_with_verifier<F, Fut>(
+    archive_path: &Path,
+    mut verify: F,
+) -> AttestationResult<bool>
+where
+    F: FnMut(&Path) -> Fut,
+    Fut: std::future::Future<Output = AttestationResult<bool>>,
+{
+    let archive_outcome = verify(archive_path).await;
+
+    // Fail closed: only consider inner files when the archive has NO
+    // attestations at all. A genuine verification failure (attestations exist
+    // but are invalid) must never trigger the fallback.
+    if !matches!(archive_outcome, Err(AttestationError::NoAttestations)) {
+        return archive_outcome;
+    }
+
+    // Only multi-file archives (tar*/zip/7z) can carry individually-attested
+    // inner files. Single-file compressions (`.gz`, `.xz`, …) and raw binaries
+    // are left to the caller's existing fallback path.
+    let file_name = archive_path
+        .file_name()
+        .map(std::ffi::OsStr::to_string_lossy)
+        .unwrap_or_default()
+        .to_string();
+    let format = TarFormat::from_file_name(&file_name);
+    if !format.is_archive() {
+        return archive_outcome;
+    }
+
+    // Bind the TempDir guard at function scope (not inside the match arm) so it
+    // outlives the `verify` calls below — the extracted files live on disk under
+    // it and the real verifier reads them.
+    let (_tmp_guard, mut inner) = match extract_regular_files(archive_path, format) {
+        Ok(pair) => pair,
+        Err(e) => {
+            debug!(
+                "could not extract {} for inner-file attestation verification \
+                 ({e}); skipping fallback",
+                archive_path.display()
+            );
+            // Behavior-preserving: don't introduce a new hard failure for a
+            // format/IO limitation. Return the original NoAttestations so the
+            // caller's SLSA/unavailable logic runs unchanged.
+            return archive_outcome;
+        }
+    };
+    // An archive with no regular files cannot be meaningfully attested "per
+    // file" — don't vacuously accept it.
+    if inner.is_empty() {
+        return archive_outcome;
+    }
+    // Deterministic probe selection (the rest of the policy keys off which file
+    // is probed first, so sort to make it stable rather than OS read_dir order).
+    inner.sort();
+
+    // Detect whether this release attests inner files *at all* by probing a
+    // single inner file. This keeps the fallback to O(1) extra API calls in the
+    // common case — a release with no attestations anywhere — preserving the
+    // rate-limit guarantee this bridge exists to maintain.
+    //
+    // - Probe is `Ok(true)` (or any non-`NoAttestations` result) → the release
+    //   attests inner files → enter STRICT mode and require every inner file to
+    //   verify.
+    // - Probe is `NoAttestations` → no evidence this release uses inner-file
+    //   attestations → return the original `NoAttestations` so the caller's
+    //   existing SLSA/unavailable fallback runs unchanged. (In a hypothetical
+    //   mixed-coverage release where the probed file is unattested but others
+    //   are not, this falls through; such coverage is not produced by real
+    //   release pipelines, which attest either all files or none.)
+    let (probe, rest) = inner
+        .split_first()
+        .expect("inner is non-empty after the is_empty check");
+    match verify(probe).await {
+        Ok(true) => {}
+        Err(AttestationError::NoAttestations) => {
+            return archive_outcome;
+        }
+        // An attestation exists for the probe but failed to verify, or a real
+        // error occurred — fail closed immediately.
+        other => {
+            return classify_inner_outcome(probe, other)
+                .expect("a non-Ok(true), non-NoAttestations outcome is always Some");
+        }
+    }
+
+    debug!(
+        "archive {} had no attestation of its own but its inner files do; \
+         requiring all {} inner file(s) to verify against GitHub attestations",
+        archive_path.display(),
+        inner.len()
+    );
+
+    // STRICT mode: the probe verified, so require every remaining inner file to
+    // verify too. Any unattested or failing file rejects the whole archive.
+    for file in rest {
+        let outcome = verify(file).await;
+        if let Some(terminal) = classify_inner_outcome(file, outcome) {
+            return terminal;
+        }
+    }
+    Ok(true)
+}
+
+/// Classify one inner file's attestation outcome into a terminal result for the
+/// whole archive, or `None` to continue to the next file.
+///
+/// This is the single source of truth for the per-file fail-closed rule used by
+/// [`verify_archive_aware_with_verifier`] in strict mode (and exercised directly
+/// in tests).
+fn classify_inner_outcome(
+    file: &Path,
+    outcome: AttestationResult<bool>,
+) -> Option<AttestationResult<bool>> {
+    match outcome {
+        Ok(true) => None,
+        // The sigstore primitives never return Ok(false) today, but treat it as
+        // a verification failure rather than success.
+        Ok(false) => Some(Err(AttestationError::Verification(format!(
+            "archive file {} exists but its GitHub artifact attestation did not verify",
+            file.display()
+        )))),
+        // The load-bearing fail-closed case (strict mode): once we know the
+        // release attests inner files, a file with no attestation breaks the
+        // "every file inside is attested" guarantee.
+        Err(AttestationError::NoAttestations) => {
+            Some(Err(AttestationError::Verification(format!(
+                "archive contains a file with no GitHub artifact attestation: {}",
+                file.display()
+            ))))
+        }
+        // A real verification/network error propagates as-is (still fail-closed).
+        Err(e) => Some(Err(e)),
+    }
+}
+
+/// Extract `archive_path` (a multi-file archive) into a fresh temp directory and
+/// return the directory guard together with the paths of every regular file it
+/// contains.
+///
+/// The caller must keep the returned [`tempfile::TempDir`] alive for as long as
+/// it reads any of the returned paths (the files live on disk under the guard).
+/// Symlinks and directories are skipped, and symlinked directories are not
+/// followed (`follow_links(false)`), so extraction cannot escape the temp
+/// directory and a symlinked target is never hashed.
+fn extract_regular_files(
+    archive_path: &Path,
+    format: TarFormat,
+) -> std::io::Result<(tempfile::TempDir, Vec<PathBuf>)> {
+    let tmp = tempfile::tempdir()?;
+    crate::file::untar(archive_path, tmp.path(), &TarOptions::new(format))
+        .map_err(|e| std::io::Error::other(e.to_string()))?;
+    let mut files = Vec::new();
+    collect_regular_files(tmp.path(), &mut files)?;
+    Ok((tmp, files))
+}
+
+/// Recursively collect every regular file under `dir`. `follow_links(false)` +
+/// `file_type().is_file()` skips symlinks (including symlinked directories) so
+/// nothing outside `dir` is ever hashed.
+fn collect_regular_files(dir: &Path, out: &mut Vec<PathBuf>) -> std::io::Result<()> {
+    for entry in walkdir::WalkDir::new(dir).follow_links(false) {
+        let entry = entry.map_err(|e| std::io::Error::other(e.to_string()))?;
+        if entry.file_type().is_file() {
+            out.push(entry.path().to_path_buf());
+        }
+    }
+    Ok(())
+}
