diff --git a/include/mbgl/util/source_location.hpp b/include/mbgl/util/source_location.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..510badf1aa4d80a9e5c455e7dc3380ec5be38284
--- /dev/null
+++ b/include/mbgl/util/source_location.hpp
@@ -0,0 +1,99 @@
+#pragma once
+
+#include <cstdint>
+
+// Some C++ standard libraries (notably the OpenHarmony / OHOS toolchain) do not
+// ship <source_location> at all. When it is available we simply alias it; when
+// it is not, we provide a stand-in that mirrors enough of its surface for
+// diagnostic call sites.
+//
+// Crucially, the fallback lives in `mbgl::util` rather than `namespace std`.
+// Adding a new type to `namespace std` is undefined behaviour (C++20
+// [namespace.constraints]/5), so we deliberately do NOT do that here.
+
+#if defined(__has_include) && __has_include(<source_location>) && \
+    defined(__cpp_lib_source_location) && __cpp_lib_source_location >= 201907L
+#include <source_location>
+#define MLN_HAVE_STD_SOURCE_LOCATION 1
+#else
+#define MLN_HAVE_STD_SOURCE_LOCATION 0
+#endif
+
+namespace mbgl {
+namespace util {
+
+#if MLN_HAVE_STD_SOURCE_LOCATION
+
+using source_location = std::source_location;
+
+#else
+
+// Compiler builtins for capturing the call site of `source_location::current()`.
+// Anything not exposed by the compiler degrades gracefully (empty function
+// name, zero column) instead of failing to compile.
+#if defined(__has_builtin) && __has_builtin(__builtin_FILE)
+#define MLN_SRCLOC_FILE() __builtin_FILE()
+#else
+#define MLN_SRCLOC_FILE() __FILE__
+#endif
+#if defined(__has_builtin) && __has_builtin(__builtin_FUNCTION)
+#define MLN_SRCLOC_FUNCTION() __builtin_FUNCTION()
+#else
+#define MLN_SRCLOC_FUNCTION() ""
+#endif
+#if defined(__has_builtin) && __has_builtin(__builtin_LINE)
+#define MLN_SRCLOC_LINE() __builtin_LINE()
+#else
+#define MLN_SRCLOC_LINE() __LINE__
+#endif
+#if defined(__has_builtin) && __has_builtin(__builtin_COLUMN)
+#define MLN_SRCLOC_COLUMN() __builtin_COLUMN()
+#else
+#define MLN_SRCLOC_COLUMN() 0u
+#endif
+
+// Drop-in, std-compatible `source_location` for toolchains without
+// <source_location>. `current()` captures the call site via default arguments
+// the same way the standard library does, so passing
+// `mbgl::util::source_location::current()` from a call site records that site
+// rather than this header.
+struct source_location {
+    static constexpr source_location current(const char* file = MLN_SRCLOC_FILE(),
+                                             const char* function = MLN_SRCLOC_FUNCTION(),
+                                             std::uint_least32_t line = MLN_SRCLOC_LINE(),
+                                             std::uint_least32_t column = MLN_SRCLOC_COLUMN()) noexcept {
+        return source_location{file, function, line, column};
+    }
+
+    constexpr source_location() noexcept = default;
+
+    constexpr std::uint_least32_t line() const noexcept { return line_; }
+    constexpr std::uint_least32_t column() const noexcept { return column_; }
+    constexpr const char* file_name() const noexcept { return file_; }
+    constexpr const char* function_name() const noexcept { return function_; }
+
+private:
+    constexpr source_location(const char* file,
+                              const char* function,
+                              std::uint_least32_t line,
+                              std::uint_least32_t column) noexcept
+        : file_(file),
+          function_(function),
+          line_(line),
+          column_(column) {}
+
+    const char* file_ = "";
+    const char* function_ = "";
+    std::uint_least32_t line_ = 0;
+    std::uint_least32_t column_ = 0;
+};
+
+#undef MLN_SRCLOC_FILE
+#undef MLN_SRCLOC_FUNCTION
+#undef MLN_SRCLOC_LINE
+#undef MLN_SRCLOC_COLUMN
+
+#endif // MLN_HAVE_STD_SOURCE_LOCATION
+
+} // namespace util
+} // namespace mbgl
