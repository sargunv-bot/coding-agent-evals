diff --git a/server/internal/database/migrations/00009_relax_overdue_action_recurring.sql b/server/internal/database/migrations/00009_relax_overdue_action_recurring.sql
new file mode 100644
index 0000000000000000000000000000000000000000..81a13f86d048a7a21e9c44350e0366c485318de9
--- /dev/null
+++ b/server/internal/database/migrations/00009_relax_overdue_action_recurring.sql
@@ -0,0 +1,32 @@
+-- +goose Up
+
+-- Relax the overdue_action_rule recurrence restriction:
+-- Remove the blanket rule that only recurring tasks may have an overdue action.
+-- set_status and clear_due_date are valid on any task type with a due date.
+-- advance_recurrence is still rejected at the API level (no recurrence to advance).
+ALTER TABLE tasks DROP CONSTRAINT chk_overdue_action_recurring;
+
+-- Remove the functional index filter on recurrence_type so overdue actions on
+-- all task types benefit from the index.
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL;
+
+-- +goose Down
+
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL
+      AND recurrence_type NOT IN ('one_off', 'on_dependency');
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
