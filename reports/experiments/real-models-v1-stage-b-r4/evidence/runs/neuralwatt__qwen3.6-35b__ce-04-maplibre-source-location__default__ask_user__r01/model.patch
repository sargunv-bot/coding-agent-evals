diff --git a/src/mbgl/util/source_location.hpp b/src/mbgl/util/source_location.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..60d477c88bdc73b0158095d20e2e0082b1a0a8ad
--- /dev/null
+++ b/src/mbgl/util/source_location.hpp
@@ -0,0 +1,67 @@
+#pragma once
+
+// Portable source_location for all C++20 toolchains.
+//
+// When the compiler / standard library provides std::source_location (C++20
+// or later with __cpp_lib_source_location), this header re-exports it
+// so all call-site diagnostics remain fully accurate.
+//
+// When std::source_location is unavailable (e.g. OpenHarmony, older libcs)
+// a lightweight fallback is provided with the same public API:
+//   - static source_location current()
+//   - file_name()           -> std::string_view
+//   - function_name()       -> std::string_view
+//   - line()                -> unsigned
+//   - column()              -> unsigned
+
+#include <cstddef>
+#include <cstdint>
+#include <string_view>
+
+// ---------------------------------------------------------------------------
+// Fallback path (e.g. OpenHarmony, older libcs without std::source_location)
+//
+// The fallback uses a struct with aggregate initialization so that the
+// SYM_GUARD_LOC macro can construct one on-the-fly at the call site:
+//     source_location { __FILE__, __FUNCTION__, __LINE__ }
+//
+// current() is provided as a no-op so code that calls it directly compiles,
+// even though it cannot capture the caller's location without compiler
+// builtins (which are only available in the std::source_location path).
+// ---------------------------------------------------------------------------
+
+struct source_location_fallback {
+    const char* const file_name_;
+    const char* const function_name_;
+    const unsigned    line_;
+    const unsigned    column_;
+
+    // 3-arg convenience: column defaults to 0
+    constexpr source_location_fallback(const char* file,
+                                       const char* func,
+                                       unsigned    line) noexcept
+        : file_name_(file), function_name_(func), line_(line), column_(0u) {}
+
+    // Full 4-arg constructor
+    constexpr source_location_fallback(const char* file,
+                                       const char* func,
+                                       unsigned    line,
+                                       unsigned    col) noexcept
+        : file_name_(file), function_name_(func), line_(line), column_(col) {}
+
+    static source_location_fallback current() noexcept {
+        return { __FILE__, __FUNCTION__, __LINE__, 0u };
+    }
+
+    constexpr std::string_view file_name()   const noexcept { return file_name_; }
+    constexpr std::string_view function_name() const noexcept { return function_name_; }
+    constexpr unsigned         line()        const noexcept { return line_; }
+    constexpr unsigned         column()      const noexcept { return column_; }
+};
+
+#if defined(__cpp_lib_source_location) && __cpp_lib_source_location >= 201907L
+#include <source_location>
+using source_location = std::source_location;
+#else
+using source_location = source_location_fallback;
+#endif
