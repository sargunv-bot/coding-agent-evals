+/// Absolute path to the composition completion test schema.
+fn composition_schema_path() -> String {
+    format!(
+        "{}/tests/fixtures/completion-composition-schema.json",
+        env!("CARGO_MANIFEST_DIR")
+    )
+}
+
+/// A test document URI for the composition schema.
+fn composition_doc_uri() -> String {
+    file_uri(&format!(
+        "{}/tests/fixtures/test-completion-composition-doc.json",
+        env!("CARGO_MANIFEST_DIR")
+    ))
+}
+
+/// Build a JSON document with an absolute $schema pointing to the composition schema.
+fn composition_doc_with_schema(content: &str) -> String {
+    let schema = composition_schema_path();
+    if content.is_empty() {
+        format!(r#"{{"$schema": "{schema}"}}"#)
+    } else {
+        format!(r#"{{"$schema": "{schema}", {content}}}"#)
+    }
+}
