index 0000000000000000000000000000000000000000..e01074a27dd1f5c4945e6f7b0b4a889c3bd15aac
--- /dev/null
+++ b/server/internal/database/migrations/00009_overdue_action_advance_recurrence_only.sql
@@ -0,0 +1,49 @@
+-- +goose Up
+
+-- Narrow the overdue-action recurrence restriction: only `advance_recurrence`
+-- requires a recurrence-driven due date. `set_status` and `clear_due_date` are
+-- meaningful for any task with a due date, including one_off and on_dependency
+-- tasks (e.g. "flip this one-off to 'overdue' when it slips"). advance_recurrence
+-- is also invalid on fixed_accumulating, whose accumulating cron owns advancement.
+
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_recurring;
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR overdue_action <> 'advance_recurrence'::overdue_action
+        OR recurrence_type NOT IN (
+            'one_off'::recurrence_type,
+            'on_dependency'::recurrence_type,
+            'fixed_accumulating'::recurrence_type
+        )
+    );
+
+-- Predicate now matches ListTasksWithOverdueActionDue exactly (the recurrence
+-- filter was the only thing excluding valid set_status/clear_due_date rows).
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL;
+
+-- +goose Down
+
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_recurring;
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL
+      AND recurrence_type NOT IN ('one_off', 'on_dependency');
