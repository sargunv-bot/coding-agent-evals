diff --git a/server/internal/database/migrations/00009_loosen_overdue_action_recurrence.sql b/server/internal/database/migrations/00009_loosen_overdue_action_recurrence.sql
new file mode 100644
index 0000000000000000000000000000000000000000..f5995cd1b348a9d900c0f79b9b2961d7f725c3a7
--- /dev/null
+++ b/server/internal/database/migrations/00009_loosen_overdue_action_recurrence.sql
@@ -0,0 +1,37 @@
+-- +goose Up
+
+-- Narrow the recurring-only constraint: set_status and clear_due_date are valid
+-- for any task with a due date, including one_off and on_dependency tasks.
+-- Only advance_recurrence (which advances a task's own due date via its
+-- recurrence rule) requires a recurrence type that computes a next due date.
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_recurring,
+    ADD CONSTRAINT chk_overdue_action_advance_recurring CHECK (
+        overdue_action IS NULL
+        OR overdue_action <> 'advance_recurrence'
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
+
+-- Rebuild the index without the recurrence_type filter so the overdue action
+-- cron can find one_off/on_dependency tasks too.
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL;
+
+-- +goose Down
+
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_advance_recurring,
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
+
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL
+      AND recurrence_type NOT IN ('one_off', 'on_dependency');
