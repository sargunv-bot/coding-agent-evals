+    def test_target_order_and_runners_preserve_current_ci_policy(self) -> None:
+        actual = [
+            (
+                target.id,
+                target.runner,
+                target.target_triple,
+                target.render_backend,
+                target.opengl_context_provider,
+            )
+            for target in self.targets
+        ]
+        self.assertEqual(EXPECTED_TARGETS, actual)
+
+    def test_workload_steps_preserve_current_ci_behavior(self) -> None:
+        actual = [
+            (workload.id, workload.name, workload.command)
+            for workload in self.workloads
+        ]
+        self.assertEqual(EXPECTED_WORKLOADS, actual)
+
+    def test_render_is_deterministic_and_current(self) -> None:
+        first = generate_workflow.render_workflow(self.targets, self.workloads)
+        second = generate_workflow.render_workflow(self.targets, self.workloads)
+        self.assertEqual(first, second)
+        self.assertTrue(generate_workflow.check_output(first))
+
+    def test_render_uses_exact_workload_membership(self) -> None:
+        rendered = generate_workflow.render_workflow(self.targets, self.workloads)
+        for workload in self.workloads:
+            self.assertIn(
+                f"if: ${{{{ contains(matrix.workloads, '{workload.id}') }}}}",
+                rendered,
+            )
+
+    def test_check_output_does_not_mutate_drifted_file(self) -> None:
+        with tempfile.TemporaryDirectory() as temporary_directory:
+            output_path = Path(temporary_directory) / "ci.yml"
+            output_path.write_text("drifted\n", encoding="utf-8")
+            with contextlib.redirect_stderr(io.StringIO()):
+                self.assertFalse(
+                    generate_workflow.check_output("generated\n", output_path)
+                )
+            self.assertEqual("drifted\n", output_path.read_text(encoding="utf-8"))
+
+    def test_target_requires_a_workload(self) -> None:
+        target = self.targets[0]
+        empty_target = generate_workflow.Target(
+            id=target.id,
+            runner=target.runner,
+            target_triple=target.target_triple,
+            render_backend=target.render_backend,
+            zig_target=target.zig_target,
+            workloads=(),
+            opengl_context_provider=target.opengl_context_provider,
+        )
+        with self.assertRaisesRegex(ValueError, "at least one workload"):
+            generate_workflow.validate_manifests(
+                [empty_target, *self.targets[1:]], self.workloads
+            )
+
+
+if __name__ == "__main__":
+    unittest.main()
