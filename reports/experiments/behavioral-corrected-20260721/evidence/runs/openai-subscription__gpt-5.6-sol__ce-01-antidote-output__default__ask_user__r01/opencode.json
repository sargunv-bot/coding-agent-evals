{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cae": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "openai-subscription",
      "options": {
        "baseURL": "https://cliproxy.home.sargunv.dev/v1",
        "apiKey": "{env:CAE_PROVIDER_API_KEY}"
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "gpt-5.6-sol"
        }
      }
    }
  },
  "mcp": {
    "proctor": {
      "type": "local",
      "command": [
        "/opt/cae/proctor-mcp"
      ],
      "enabled": true,
      "timeout": 1800000
    }
  }
}
