+    fn create_tar(entries: &[(&str, &[u8])]) -> (tempfile::TempDir, PathBuf) {
+        let temp_dir = tempfile::tempdir().unwrap();
+        let archive_path = temp_dir.path().join("artifact.tar");
+        let file = std::fs::File::create(&archive_path).unwrap();
+        let mut builder = tar::Builder::new(file);
+        for (name, contents) in entries {
+            let mut header = tar::Header::new_gnu();
+            header.set_size(contents.len() as u64);
+            header.set_mode(0o755);
+            header.set_cksum();
+            builder.append_data(&mut header, name, *contents).unwrap();
+        }
+        builder.finish().unwrap();
+        (temp_dir, archive_path)
+    }
+
+    #[derive(Clone, Copy)]
+    enum TestVerification {
+        Verified,
+        Rejected,
+        Missing,
+        ApiError,
+    }
+
+    struct TestVerifier {
+        artifact_path: PathBuf,
+        results: HashMap<String, TestVerification>,
+        calls: Arc<Mutex<Vec<String>>>,
+    }
+
+    impl AttestationVerifier for TestVerifier {
+        fn verify<'a>(&'a mut self, path: &'a Path) -> VerifyFuture<'a> {
+            let key = if path == self.artifact_path {
+                "archive".to_string()
+            } else {
+                path.file_name().unwrap().to_string_lossy().into_owned()
+            };
+            self.calls.lock().unwrap().push(key.clone());
+            let result = match self.results.remove(&key).unwrap() {
+                TestVerification::Verified => Ok(true),
+                TestVerification::Rejected => Ok(false),
+                TestVerification::Missing => Err(AttestationError::NoAttestations),
+                TestVerification::ApiError => Err(AttestationError::Api("unavailable".into())),
+            };
+            Box::pin(async move { result })
+        }
+    }
+
+    fn test_verifier(
+        artifact_path: PathBuf,
+        results: HashMap<String, TestVerification>,
+    ) -> (Arc<Mutex<Vec<String>>>, TestVerifier) {
+        let calls = Arc::new(Mutex::new(Vec::new()));
+        let verifier = TestVerifier {
+            artifact_path,
+            results,
+            calls: calls.clone(),
+        };
+        (calls, verifier)
+    }
