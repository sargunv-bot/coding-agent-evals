{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cae": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kimi-subscription",
      "options": {
        "baseURL": "https://cliproxy.home.sargunv.dev/v1",
        "apiKey": "{env:CAE_PROVIDER_API_KEY}"
      },
      "models": {
        "kimi-k3": {
          "name": "kimi-k3"
        }
      }
    }
  },
  "mcp": {
    "proctor": {
      "type": "local",
      "command": [
        "/opt/cae/proctor-mcp"
      ],
      "enabled": true,
      "timeout": 1800000
    }
  }
}
