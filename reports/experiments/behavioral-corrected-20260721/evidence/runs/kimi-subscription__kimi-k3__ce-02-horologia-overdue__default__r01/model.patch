diff --git a/server/internal/database/migrations/00009_overdue_action_non_recurring.sql b/server/internal/database/migrations/00009_overdue_action_non_recurring.sql
new file mode 100644
index 0000000000000000000000000000000000000000..da24246485ca01360fb00026b9ac241fcd910363
--- /dev/null
+++ b/server/internal/database/migrations/00009_overdue_action_non_recurring.sql
@@ -0,0 +1,37 @@
+-- +goose Up
+
+-- Overdue action rules were previously restricted to recurring task types
+-- wholesale. Only advance_recurrence actually needs a recurrence schedule;
+-- set_status and clear_due_date are meaningful on one_off and on_dependency
+-- tasks too (and the web UI already offers them there).
+ALTER TABLE tasks
+    DROP CONSTRAINT chk_overdue_action_recurring,
+    ADD CONSTRAINT chk_overdue_action_advance_recurring CHECK (
+        overdue_action IS NULL
+        OR overdue_action <> 'advance_recurrence'::overdue_action
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
+
+-- The cron now picks up one_off/on_dependency tasks with set_status or
+-- clear_due_date rules, so the partial index must cover them.
+DROP INDEX idx_tasks_overdue_action;
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL;
+
+-- +goose Down
+
+DROP INDEX idx_tasks_overdue_action;
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL
+      AND recurrence_type NOT IN ('one_off', 'on_dependency');
+
+ALTER TABLE tasks
+    DROP CONSTRAINT chk_overdue_action_advance_recurring,
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
