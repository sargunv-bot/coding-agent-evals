+    use async_trait::async_trait;
+    use std::collections::HashMap;
+    use std::path::Path;
+
+    /// Test-only verifier that returns deterministic results per file name.
+    struct MockVerifier {
+        results: HashMap<String, std::result::Result<bool, VerificationStatus>>,
+        default: std::result::Result<bool, VerificationStatus>,
+    }
+
+    impl MockVerifier {
+        fn new() -> Self {
+            Self {
+                results: HashMap::new(),
+                default: Err(VerificationStatus::NoAttestations),
+            }
+        }
+
+        fn with_result(
+            mut self,
+            name: &str,
+            result: std::result::Result<bool, VerificationStatus>,
+        ) -> Self {
+            self.results.insert(name.to_string(), result);
+            self
+        }
+
+        fn with_default(mut self, result: std::result::Result<bool, VerificationStatus>) -> Self {
+            self.default = result;
+            self
+        }
+    }
+
+    #[async_trait]
+    impl AttestationVerifier for MockVerifier {
+        async fn verify_blob(&self, path: &Path) -> std::result::Result<bool, VerificationStatus> {
+            let name = path
+                .file_name()
+                .expect("test path has file name")
+                .to_string_lossy()
+                .to_string();
+            self.results
+                .get(&name)
+                .cloned()
+                .unwrap_or(self.default.clone())
+        }
+    }
+
+    fn write_test_file(dir: &Path, relative: &str, content: &[u8]) -> std::path::PathBuf {
+        let path = dir.join(relative);
+        if let Some(parent) = path.parent() {
+            std::fs::create_dir_all(parent).unwrap();
+        }
+        std::fs::write(&path, content).unwrap();
+        path
+    }
+
+    fn create_test_tar_gz(source: &Path, archive: &Path, follow_symlinks: bool) {
+        let out = std::fs::File::create(archive).unwrap();
+        let enc = flate2::write::GzEncoder::new(out, flate2::Compression::default());
+        let mut tar = tar::Builder::new(enc);
+        tar.follow_symlinks(follow_symlinks);
+        tar.append_dir_all(".", source).unwrap();
+        tar.finish().unwrap();
+    }
+
+    fn create_test_zip(source: &Path, archive: &Path) {
+        let out = std::fs::File::create(archive).unwrap();
+        let mut zip = zip::ZipWriter::new(out);
+        let options = zip::write::SimpleFileOptions::default()
+            .compression_method(zip::CompressionMethod::Deflated);
+        for entry in WalkDir::new(source).sort_by_file_name() {
+            let entry = entry.unwrap();
+            let path = entry.path();
+            let name = path.strip_prefix(source).unwrap();
+            if path.is_symlink() {
+                continue;
+            }
+            if path.is_file() {
+                zip.start_file_from_path(name, options).unwrap();
+                let mut f = std::fs::File::open(path).unwrap();
+                std::io::copy(&mut f, &mut zip).unwrap();
+            } else if path.is_dir() && !name.as_os_str().is_empty() {
+                zip.add_directory_from_path(name, options).unwrap();
+            }
+        }
+        zip.finish().unwrap();
+    }
