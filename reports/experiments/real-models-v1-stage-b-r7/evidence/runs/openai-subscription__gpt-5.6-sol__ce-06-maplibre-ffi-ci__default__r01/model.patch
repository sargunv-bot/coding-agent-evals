+# Ordered variant-job steps and the variants on which each step is supported.
+
+[[steps]]
+id = "native-build"
+name = "Build native library"
+run = "mise run build"
+targets = ["ios-arm64-metal", "ios-simulator-arm64-metal"]
+
+[[steps]]
+id = "native-test"
+name = "Test native library"
+run = "mise run test"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "macos-arm64-egl",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "java-ffm"
+name = "Build Java FFM binding"
+run = "mise run //bindings/java-ffm:build"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "java-jni"
+name = "Build Java JNI binding"
+run = "mise run //bindings/java-jni:build"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "dotnet"
+name = "Test .NET binding"
+run = "mise run //bindings/dotnet:test"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "kotlin-native"
+name = "Test Kotlin/Native binding"
+run = "mise run //bindings/kotlin-native:build"
+comment = """
+linux-arm64: no Kotlin/Native host - https://youtrack.jetbrains.com/issue/KT-36871
+windows: no MSVC target - https://youtrack.jetbrains.com/issue/SKIKO-446
+"""
+targets = [
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+]
+
+[[steps]]
+id = "rust-binding"
+name = "Test Rust binding"
+run = "mise run //bindings/rust:ci"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "swift-binding"
+name = "Test Swift binding"
+run = "mise run //bindings/swift:test"
+targets = ["macos-arm64-metal", "macos-arm64-vulkan"]
+
+[[steps]]
+id = "zig-binding"
+name = "Test Zig binding"
+run = "mise run //bindings/zig:ci"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "macos-arm64-egl",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "lwjgl-example"
+name = "Build LWJGL example"
+run = "mise run //examples/lwjgl-map:build"
+targets = [
+  "linux-arm64-vulkan",
+  "linux-x64-vulkan",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+]
+
+[[steps]]
+id = "rust-example"
+name = "Test Rust example"
+run = "mise run //examples/rust-map:ci"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "swift-example"
+name = "Build Swift example"
+run = "mise run //examples/swift-map:build"
+targets = ["macos-arm64-metal"]
+
+[[steps]]
+id = "zig-example"
+name = "Build Zig example"
+run = "mise run //examples/zig-map:build"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
+
+[[steps]]
+id = "zig-readback"
+name = "Run Zig readback example"
+run = "mise run //examples/zig-readback:run"
+targets = [
+  "linux-arm64-egl",
+  "linux-arm64-vulkan",
+  "linux-x64-egl",
+  "linux-x64-vulkan",
+  "macos-arm64-metal",
+  "macos-arm64-vulkan",
+  "macos-arm64-egl",
+  "windows-x64-vulkan",
+  "windows-x64-wgl",
+]
