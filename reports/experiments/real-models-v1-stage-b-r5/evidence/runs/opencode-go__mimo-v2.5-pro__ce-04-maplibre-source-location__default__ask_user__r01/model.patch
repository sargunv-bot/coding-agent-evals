diff --git a/include/mbgl/util/source_location.hpp b/include/mbgl/util/source_location.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..86a813f37d0fc3e2b1fa7cd25729450ccf72f891
--- /dev/null
+++ b/include/mbgl/util/source_location.hpp
@@ -0,0 +1,51 @@
+#pragma once
+
+#if __has_include(<source_location>) && defined(__cpp_lib_source_location) && \
+    (__cpp_lib_source_location >= 201907L)
+#define MBGL_HAS_STD_SOURCE_LOCATION 1
+#include <source_location>
+namespace mbgl {
+using source_location = std::source_location;
+} // namespace mbgl
+#define MBGL_SOURCE_LOCATION_CURRENT() std::source_location::current()
+
+#elif defined(__has_builtin) && __has_builtin(__builtin_FILE) && \
+    __has_builtin(__builtin_FUNCTION) && __has_builtin(__builtin_LINE)
+#define MBGL_HAS_BUILTIN_SOURCE_LOCATION 1
+namespace mbgl {
+struct source_location {
+    const char* file_name_;
+    const char* function_name_;
+    unsigned line_;
+    unsigned column_;
+
+    constexpr const char* file_name() const noexcept { return file_name_; }
+    constexpr const char* function_name() const noexcept { return function_name_; }
+    constexpr unsigned line() const noexcept { return line_; }
+    constexpr unsigned column() const noexcept { return column_; }
+};
+} // namespace mbgl
+#define MBGL_SOURCE_LOCATION_CURRENT() \
+    mbgl::source_location {            \
+        __builtin_FILE(), __builtin_FUNCTION(), __builtin_LINE(), 0 \
+    }
+
+#else
+namespace mbgl {
+struct source_location {
+    const char* file_name_;
+    const char* function_name_;
+    unsigned line_;
+    unsigned column_;
+
+    constexpr const char* file_name() const noexcept { return file_name_; }
+    constexpr const char* function_name() const noexcept { return function_name_; }
+    constexpr unsigned line() const noexcept { return line_; }
+    constexpr unsigned column() const noexcept { return column_; }
+};
+} // namespace mbgl
+#define MBGL_SOURCE_LOCATION_CURRENT() \
+    mbgl::source_location {            \
+        __FILE__, __func__, __LINE__, 0 \
+    }
+#endif
