diff --git a/include/mbgl/util/source_location.hpp b/include/mbgl/util/source_location.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..741337fe0529f3abd602c6f373d62d6841e3335a
--- /dev/null
+++ b/include/mbgl/util/source_location.hpp
@@ -0,0 +1,37 @@
+#pragma once
+
+#include <cstdint>
+
+#if __has_include(<source_location>)
+#include <source_location>
+#endif
+
+namespace mbgl {
+
+#if __has_include(<source_location>)
+using source_location = std::source_location;
+#else
+struct source_location {
+    const char* file_{};
+    const char* function_{};
+    std::uint_least32_t line_{};
+
+    constexpr source_location() = default;
+    constexpr source_location(const char* file, const char* function, std::uint_least32_t line) noexcept
+        : file_(file), function_(function), line_(line) {}
+
+    constexpr std::uint_least32_t line() const noexcept { return line_; }
+    constexpr std::uint_least32_t column() const noexcept { return 0; }
+    constexpr const char* file_name() const noexcept { return file_; }
+    constexpr const char* function_name() const noexcept { return function_; }
+};
+#endif
+
+} // namespace mbgl
+
+#if __has_include(<source_location>)
+#define MBGL_CURRENT_LOCATION ::mbgl::source_location::current()
+#else
+#define MBGL_CURRENT_LOCATION \
+    ::mbgl::source_location { __FILE__, __FUNCTION__, static_cast<std::uint_least32_t>(__LINE__) }
+#endif
