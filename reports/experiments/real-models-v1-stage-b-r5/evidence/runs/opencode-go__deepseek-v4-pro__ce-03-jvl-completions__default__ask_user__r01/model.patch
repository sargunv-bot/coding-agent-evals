+/// Shortcut for composed completion schema path.
+fn composed_schema_path() -> String {
+    format!(
+        "{}/tests/fixtures/completion-composed-schema.json",
+        env!("CARGO_MANIFEST_DIR")
+    )
+}
+
+/// Build a document with the composed schema and a property value position,
+/// returning the cursor column and the full content.
+///
+/// `property` is the key name and `placeholder` is the dummy value that
+/// follows the colon (e.g. `"null"`).  The cursor is placed right after the
+/// `": "` separator.
+fn composed_value_doc(property: &str, placeholder: &str) -> (u32, String) {
+    let schema = composed_schema_path();
+    let content = format!(r#"{{"$schema": "{schema}", "{property}": {placeholder}}}"#);
+    let needle = format!(r#""{property}": "#);
+    let cursor_col = content.find(&needle).unwrap() + needle.len();
+    (cursor_col as u32, content)
+}
+
+/// OneOf const value completion.
+#[tokio::test]
+async fn completion_oneof_const_values() {
+    let mut client = TestClient::new();
+    client.initialize().await;
+
+    let (cursor_col, content) = composed_value_doc("color", "null");
+    let uri = doc_uri();
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let result = client.completion(&uri, 0, cursor_col).await;
+    let names = labels(&result);
+    assert!(
+        names.contains(&r#""red""#.to_string()),
+        "expected '\"red\"' in oneOf const completions, got: {names:?}"
+    );
+    assert!(
+        names.contains(&r#""green""#.to_string()),
+        "expected '\"green\"' in oneOf const completions, got: {names:?}"
+    );
+    assert!(
+        names.contains(&r#""blue""#.to_string()),
+        "expected '\"blue\"' in oneOf const completions, got: {names:?}"
+    );
+}
+
