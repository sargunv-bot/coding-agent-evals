+/// No duplicate suggestions when anyOf branches overlap.
+#[tokio::test]
+async fn completion_anyof_no_duplicates() {
+    let mut client = TestClient::new();
+    client.initialize().await;
+
+    // Schema with overlapping anyOf branches (both define "name").
+    let schema = serde_json::json!({
+        "type": "object",
+        "anyOf": [
+            { "properties": { "name": { "type": "string" } } },
+            { "properties": { "name": { "type": "string" } } }
+        ]
+    });
+    let schema_str = schema.to_string();
+
+    let tmp = tempfile::NamedTempFile::new().unwrap();
+    std::fs::write(tmp.path(), &schema_str).unwrap();
+    let schema_path = tmp.path().to_str().unwrap();
+
+    let content = format!(r#"{{"$schema": "{schema_path}"}}"#);
+    let uri = file_uri("/tmp/test-anyof-dedup.json");
+
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let cursor_col = (content.len() - 1) as u32;
+    let result = client.completion(&uri, 0, cursor_col).await;
+
+    let names = labels(&result);
+    let name_count = names.iter().filter(|n| n.as_str() == "name").count();
+    assert_eq!(
+        name_count, 1,
+        "'name' should appear exactly once, got {name_count} times in: {names:?}"
+    );
+}
