{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cae": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "opencode-go",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:CAE_PROVIDER_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro"
        }
      }
    }
  },
  "mcp": {
    "proctor": {
      "type": "local",
      "command": [
        "/opt/cae/proctor-mcp"
      ],
      "enabled": true,
      "timeout": 1800000
    }
  }
}
