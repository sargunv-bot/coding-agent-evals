diff --git a/server/internal/database/migrations/00009_overdue_action_non_recurring.sql b/server/internal/database/migrations/00009_overdue_action_non_recurring.sql
new file mode 100644
index 0000000000000000000000000000000000000000..b2aa7e37fa865511f383463759c90dbc791c681f
--- /dev/null
+++ b/server/internal/database/migrations/00009_overdue_action_non_recurring.sql
@@ -0,0 +1,41 @@
+-- +goose Up
+
+-- Replace the blanket one_off/on_dependency rejection with a targeted rule that
+-- only blocks advance_recurrence on non-recurring task types. set_status and
+-- clear_due_date are valid for any task with a due date.
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_recurring;
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR overdue_action != 'advance_recurrence'
+        OR recurrence_type NOT IN ('one_off', 'on_dependency')
+    );
+
+-- Rebuild the functional index to include one_off and on_dependency tasks.
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL;
+
+-- +goose Down
+
+DROP INDEX IF EXISTS idx_tasks_overdue_action;
+
+CREATE INDEX idx_tasks_overdue_action
+    ON tasks ((due_at + COALESCE(overdue_action_after_days, 0)))
+    WHERE overdue_action IS NOT NULL
+      AND due_at IS NOT NULL
+      AND recurrence_type NOT IN ('one_off', 'on_dependency');
+
+ALTER TABLE tasks
+    DROP CONSTRAINT IF EXISTS chk_overdue_action_recurring;
+
+ALTER TABLE tasks
+    ADD CONSTRAINT chk_overdue_action_recurring CHECK (
+        overdue_action IS NULL
+        OR recurrence_type NOT IN ('one_off'::recurrence_type, 'on_dependency'::recurrence_type)
+    );
