+++ b/.github/ci/variants.yaml
@@ -0,0 +1,209 @@
+# Source of truth for CI variant matrix and target support policy.
+#
+# Each entry defines a CI target (variant) and the bindings/examples it supports.
+# The generator (scripts/generate-ci.py) reads this file and produces
+# .github/workflows/ci.yml variants job sections (matrix + steps).
+#
+# Format
+# ======
+# targets:
+#   - name: <mise_env>                  # unique, matches .mise/config.<name>.toml
+#     runner: <GitHub Actions runner>    # e.g. ubuntu-latest, macos-latest
+#     os: <linux|macos|ios|windows>     # used by generator for defaults
+#     arch: <x64|arm64>                # used by generator for defaults
+#
+# bindings:
+#   - name: <binding-name>              # maps to //bindings/<name>:<command>
+#     command: build|test
+#     supports:
+#       targets: [<target names>]        # explicit list of supported targets
+#
+# examples:
+#   - name: <example-name>              # maps to //examples/<name>:<command>
+#     command: build|run|ci
+#     supports:
+#       targets: [<target names>]
+#
+# Rules
+# =====
+# Every target must appear in at least one supports.targets list (it builds and
+# tests the native library itself). If a binding or example does _not_ list a
+# target, it is skipped for that target — no need for exclusion patterns.
+#
+# Add a new target: add an entry + update every binding/example supports.targets.
+# Add a new binding/example: add it to bindings/examples + populate supported targets.
+
+targets:
+  - name: linux-arm64-egl
+    runner: ubuntu-24.04-arm
+    os: linux
+    arch: arm64
+  - name: linux-arm64-vulkan
+    runner: ubuntu-24.04-arm
+    os: linux
+    arch: arm64
+  - name: linux-x64-egl
+    runner: ubuntu-latest
+    os: linux
+    arch: x64
+  - name: linux-x64-vulkan
+    runner: ubuntu-latest
+    os: linux
+    arch: x64
+  - name: macos-arm64-metal
+    runner: macos-latest
+    os: macos
+    arch: arm64
+  - name: macos-arm64-vulkan
+    runner: macos-latest
+    os: macos
+    arch: arm64
+  - name: macos-arm64-egl
+    runner: macos-latest
+    os: macos
+    arch: arm64
+  - name: ios-arm64-metal
+    runner: macos-latest
+    os: ios
+    arch: arm64
+  - name: ios-simulator-arm64-metal
+    runner: macos-latest
+    os: ios
+    arch: arm64
+  - name: windows-x64-vulkan
+    runner: windows-2022
+    os: windows
+    arch: x64
+  - name: windows-x64-wgl
+    runner: windows-2022
+    os: windows
+    arch: x64
+
+bindings:
+  - name: java-ffm
+    command: build
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  # kotlin: Gradle — https://youtrack.jetbrains.com/issue/KT-36871
+  - name: kotlin-native
+    command: build
+    supports:
+      targets:
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+  - name: dotnet
+    command: test
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  - name: rust
+    command: ci
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  - name: swift
+    command: test
+    supports:
+      targets:
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+  - name: zig
+    command: ci
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - macos-arm64-egl
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  - name: java-jni
+    command: build
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - windows-x64-vulkan
+        - windows-x64-wgl
+
+examples:
+  - name: lwjgl-map
+    command: build
+    supports:
+      targets:
+        - linux-arm64-vulkan
+        - linux-x64-vulkan
+        - windows-x64-vulkan
+  - name: rust-map
+    command: ci
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  - name: zig-map
+    command: build
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  - name: zig-readback
+    command: run
+    supports:
+      targets:
+        - linux-arm64-egl
+        - linux-arm64-vulkan
+        - linux-x64-egl
+        - linux-x64-vulkan
+        - macos-arm64-metal
+        - macos-arm64-vulkan
+        - macos-arm64-egl
+        - windows-x64-vulkan
+        - windows-x64-wgl
+  - name: swift-map
+    command: build
+    supports:
+      targets:
+        - macos-arm64-metal
