+# CI target support policy.
+# This file is the single source of truth for the variant matrix in
+# `.github/workflows/ci.yml`. Edit it, then regenerate the workflow with:
+#
+#   mise run ci:generate
+#
+# CI enforces that the checked-in workflow stays in sync with this manifest.
+
+# Steps are rendered in order under the `variants` job. Each step either always
+# runs, runs only on build-only targets, runs only on test targets, or runs when
+# the target declares the named capability.
+[[step]]
+name = "Configure native library"
+task = "mise run configure"
+always = true
+
+[[step]]
+name = "Build native library"
+task = "mise run build"
+build_only = true
+
+[[step]]
+name = "Test native library"
+task = "mise run test"
+test_only = true
+
+[[step]]
+name = "Build Java FFM binding"
+task = "mise run //bindings/java-ffm:build"
+capability = "java-ffm"
+
+[[step]]
+name = "Build Java JNI binding"
+task = "mise run //bindings/java-jni:build"
+capability = "java-jni"
+
+[[step]]
+name = "Test .NET binding"
+task = "mise run //bindings/dotnet:test"
+capability = "dotnet"
+
+[[step]]
+name = "Test Kotlin/Native binding"
+task = "mise run //bindings/kotlin-native:build"
+capability = "kotlin-native"
+
+[[step]]
+name = "Test Rust binding"
+task = "mise run //bindings/rust:ci"
+capability = "rust"
+
+[[step]]
+name = "Test Swift binding"
+task = "mise run //bindings/swift:test"
+capability = "swift"
+
+[[step]]
+name = "Test Zig binding"
+task = "mise run //bindings/zig:ci"
+capability = "zig"
+
+[[step]]
+name = "Build LWJGL example"
+task = "mise run //examples/lwjgl-map:build"
+capability = "lwjgl-example"
+
+[[step]]
+name = "Test Rust example"
+task = "mise run //examples/rust-map:ci"
+capability = "rust-example"
+
+[[step]]
+name = "Build Swift example"
+task = "mise run //examples/swift-map:build"
+capability = "swift-example"
+
+[[step]]
+name = "Build Zig example"
+task = "mise run //examples/zig-map:build"
+capability = "zig-example"
+
+[[step]]
+name = "Run Zig readback example"
+task = "mise run //examples/zig-readback:run"
+capability = "zig-readback"
+
+# Supported CI targets. `capabilities` lists the step capabilities that run for
+# the target. `build_only = true` skips the native test step and all binding and
+# example steps (the target only checks that the native library builds).
+
+[[target]]
+name = "linux-arm64-egl"
+runner = "ubuntu-24.04-arm"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  # "kotlin-native" excluded: no Kotlin/Native host on linux-arm64 —
+  # https://youtrack.jetbrains.com/issue/KT-36871
+  "rust",
+  "zig",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "linux-arm64-vulkan"
+runner = "ubuntu-24.04-arm"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  # "kotlin-native" excluded: no Kotlin/Native host on linux-arm64 —
+  # https://youtrack.jetbrains.com/issue/KT-36871
+  "rust",
+  "zig",
+  "lwjgl-example",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "linux-x64-egl"
+runner = "ubuntu-latest"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  "kotlin-native",
+  "rust",
+  "zig",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "linux-x64-vulkan"
+runner = "ubuntu-latest"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  "kotlin-native",
+  "rust",
+  "zig",
+  "lwjgl-example",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "macos-arm64-metal"
+runner = "macos-latest"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  "kotlin-native",
+  "rust",
+  "swift",
+  "zig",
+  "rust-example",
+  "swift-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "macos-arm64-vulkan"
+runner = "macos-latest"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  "kotlin-native",
+  "rust",
+  "swift",
+  "zig",
+  "lwjgl-example",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "macos-arm64-egl"
+runner = "macos-latest"
+build_only = false
+capabilities = [
+  # ANGLE/EGL smoke build on macOS. Most bindings and examples are skipped while
+  # the EGL backend is experimental.
+  "zig",
+  "zig-readback",
+]
+
+[[target]]
+name = "ios-arm64-metal"
+runner = "macos-latest"
+build_only = true
+capabilities = []
+notes = "Cross-compiled iOS build only; no simulator or test execution in CI."
+
+[[target]]
+name = "ios-simulator-arm64-metal"
+runner = "macos-latest"
+build_only = true
+capabilities = []
+notes = "Cross-compiled iOS simulator build only; no test execution in CI."
+
+[[target]]
+name = "windows-x64-vulkan"
+runner = "windows-2022"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  # "kotlin-native" excluded: no Kotlin/Native MSVC target —
+  # https://youtrack.jetbrains.com/issue/SKIKO-446
+  "rust",
+  "zig",
+  "lwjgl-example",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
+
+[[target]]
+name = "windows-x64-wgl"
+runner = "windows-2022"
+build_only = false
+capabilities = [
+  "java-ffm",
+  "java-jni",
+  "dotnet",
+  # "kotlin-native" excluded: no Kotlin/Native MSVC target —
+  # https://youtrack.jetbrains.com/issue/SKIKO-446
+  "rust",
+  "zig",
+  "rust-example",
+  "zig-example",
+  "zig-readback",
+]
