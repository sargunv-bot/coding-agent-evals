+    // {"$schema": "...", "description": null}
+    let content = doc_with_schema(r#""description": null"#);
+    let uri = doc_uri();
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let idx = content.find("\"description\": ").unwrap() + "\"description\": ".len();
+    let cursor_col = idx as u32;
+    let result = client.completion(&uri, 0, cursor_col).await;
+
+    let names = labels(&result);
+    assert!(
+        names.contains(&"null".to_string()),
+        "expected 'null' from type array, got: {names:?}"
+    );
+}
+
+/// Nullable keyword (nullable: true) provides null suggestion.
+#[tokio::test]
+async fn completion_nullable_keyword() {
+    let mut client = TestClient::new();
+    client.initialize().await;
+
+    // {"$schema": "...", "nickname": null}
+    let content = doc_with_schema(r#""nickname": null"#);
+    let uri = doc_uri();
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let idx = content.find("\"nickname\": ").unwrap() + "\"nickname\": ".len();
+    let cursor_col = idx as u32;
+    let result = client.completion(&uri, 0, cursor_col).await;
+
+    let names = labels(&result);
+    assert!(
+        names.contains(&"null".to_string()),
+        "expected 'null' from nullable keyword, got: {names:?}"
+    );
+}
+
+/// anyOf branches with overlapping values produce deduplicated suggestions.
+#[tokio::test]
+async fn completion_no_deduplicated_suggestions() {
+    let mut client = TestClient::new();
+    client.initialize().await;
+
+    // {"$schema": "...", "mode": null}
+    let content = doc_with_schema(r#""mode": null"#);
+    let uri = doc_uri();
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let idx = content.find("\"mode\": ").unwrap() + "\"mode\": ".len();
+    let cursor_col = idx as u32;
+    let result = client.completion(&uri, 0, cursor_col).await;
+
+    let items = result["items"].as_array().unwrap();
+    let dark_count = items.iter().filter(|i| i["label"] == r#""dark""#).count();
+    assert_eq!(dark_count, 1, "expected exactly one 'dark' suggestion, got {dark_count}");
+
+    let light_count = items.iter().filter(|i| i["label"] == r#""light""#).count();
+    assert_eq!(light_count, 1, "expected exactly one 'light' suggestion, got {light_count}");
+
+    let auto_count = items.iter().filter(|i| i["label"] == r#""auto""#).count();
+    assert_eq!(auto_count, 1, "expected exactly one 'auto' suggestion, got {auto_count}");
+}
+
+/// Nested anyOf inside allOf property completions work.
+#[tokio::test]
+async fn completion_nested_composed_properties() {
+    let mut client = TestClient::new();
+    client.initialize().await;
+
+    // {"$schema": "...", "server": {}}
+    let content = doc_with_schema(r#""server": {}"#);
+    let uri = doc_uri();
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let inner_brace = content.rfind('{').unwrap();
+    let cursor_col = (inner_brace + 1) as u32;
+    let result = client.completion(&uri, 0, cursor_col).await;
+
+    let names = labels(&result);
+    assert!(
+        names.contains(&"host".to_string()),
+        "expected 'host' from allOf inside server, got: {names:?}"
+    );
+    assert!(
+        names.contains(&"port".to_string()),
+        "expected 'port' from anyOf inside allOf within server, got: {names:?}"
+    );
+}
