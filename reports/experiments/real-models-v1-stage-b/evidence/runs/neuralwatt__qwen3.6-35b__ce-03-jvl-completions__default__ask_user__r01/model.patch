+/// anyOf property completions merge properties from all branches.
+#[tokio::test]
+async fn completion_allof_anyof_properties_merged() {
+    let mut client = TestClient::new();
+    client.initialize().await;
+
+    // {"$schema": "...", "tags": {}}
+    let content = doc_with_schema(r#""tags": {}"#);
+    let uri = doc_uri();
+    open_and_wait(&mut client, &uri, &content).await;
+
+    let inner_brace = content.rfind('{').unwrap();
+    let cursor_col = (inner_brace + 1) as u32;
+    let result = client.completion(&uri, 0, cursor_col).await;
+
+    let names = labels(&result);
+    assert!(
+        names.contains(&"primary".to_string()),
+        "expected 'primary' from anyOf branch, got: {names:?}"
+    );
+    assert!(
+        names.contains(&"label".to_string()),
+        "expected 'label' from anyOf branch, got: {names:?}"
+    );
+}
+
