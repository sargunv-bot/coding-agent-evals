+/// Supported archive formats for per-file attestation extraction.
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub enum TarFormat {
+    TarGz,
+    TarXz,
+    TarBz2,
+    TarZst,
+    Gz,
+    Xz,
+    Bz2,
+    Zst,
+    Tar,
+    Zip,
+    SevenZip,
+    Raw,
+}
+
+impl TarFormat {
+    pub fn from_file_name(filename: &str) -> Self {
+        let filename = filename.to_lowercase();
+        if let Some(idx) = filename.rfind(".tar.") {
+            let ext = &filename[idx + 5..];
+            return Self::from_ext(ext);
+        }
+        if let Some(ext) = std::path::Path::new(&filename)
+            .extension()
+            .and_then(|s| s.to_str())
+        {
+            Self::from_ext(ext)
+        } else {
+            TarFormat::Raw
+        }
+    }
+
+    fn from_ext(ext: &str) -> Self {
+        match ext.to_lowercase().as_str() {
+            "tar.gz" | "tgz" => TarFormat::TarGz,
+            "gz" => TarFormat::Gz,
+            "tar.xz" | "txz" => TarFormat::TarXz,
+            "xz" => TarFormat::Xz,
+            "tar.bz2" | "tbz2" => TarFormat::TarBz2,
+            "bz2" => TarFormat::Bz2,
+            "tar.zst" | "tzst" => TarFormat::TarZst,
+            "zst" => TarFormat::Zst,
+            "tar" => TarFormat::Tar,
+            "zip" | "vsix" => TarFormat::Zip,
+            "7z" => TarFormat::SevenZip,
+            "raw" => TarFormat::Raw,
+            _ => TarFormat::Raw,
+        }
+    }
+
+    pub fn is_archive(&self) -> bool {
+        matches!(
+            self,
+            TarFormat::TarGz
+                | TarFormat::TarXz
+                | TarFormat::TarBz2
+                | TarFormat::TarZst
+                | TarFormat::Tar
+                | TarFormat::Zip
+                | TarFormat::SevenZip
+        )
+    }
+}
+
+fn open_tar(format: TarFormat, archive: &std::path::Path) -> std::io::Result<Box<dyn std::io::Read>> {
+    let base = std::fs::File::open(archive)?;
+    let result: Box<dyn std::io::Read> = match format {
+        TarFormat::TarGz | TarFormat::Gz => Box::new(GzDecoder::new(base)),
+        TarFormat::TarXz | TarFormat::Xz => Box::new(xz2::read::XzDecoder::new(base)),
+        TarFormat::TarBz2 | TarFormat::Bz2 => Box::new(BzDecoder::new(base)),
+        TarFormat::Tar => Box::new(base),
+        _ => Box::new(base),
+    };
+    Ok(result)
+}
