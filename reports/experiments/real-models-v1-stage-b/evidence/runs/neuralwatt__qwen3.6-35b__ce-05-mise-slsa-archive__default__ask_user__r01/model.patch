+/// Verify archive-level GitHub artifact attestations **and** per-file attestations
+/// for files extracted from an archive.
+///
+/// Some GitHub releases publish attestations for individual files inside an archive
+/// (e.g. the extracted binary) rather than the archive blob itself. This function
+/// handles both cases:
+///
+/// 1. First, attempt archive-level verification against the archive's SHA-256 digest.
+/// 2. If that fails with "no attestations found" (the tool simply has no archive-level
+///    attestation), extract the archive and check each extracted file.
+/// 3. For each extracted file, query the GitHub attestation API and verify bundles.
+///
+/// Returns `Ok(true)` if any attestation (archive-level or per-file) verified
+/// successfully. Returns `Ok(false)` only when extraction succeeds but no
+/// attestations exist for the archive or any extracted file. Propagates errors for
+/// anything else (extraction failure, API errors, verified-attestation-but-subject
+/// mismatch).
+///
+/// `file_path` is the downloaded archive. `owner`/`repo` identify the GitHub source.
+pub async fn verify_github_file_attestations(
+    file_path: &Path,
+    owner: &str,
+    repo: &str,
+    token: Option<&str>,
+    signer_workflow: Option<&str>,
+    api_url: Option<&str>,
+) -> Result<bool> {
+    verify_github_file_attestations_inner(
+        file_path, owner, repo, token, signer_workflow, api_url,
+    )
+    .await
+}
+
+/// Like [`verify_github_file_attestations`] but accepts an explicit base URL
+/// (for GitHub Enterprise).
+pub async fn verify_github_file_attestations_with_base_url(
+    file_path: &Path,
+    owner: &str,
+    repo: &str,
+    token: Option<&str>,
+    signer_workflow: Option<&str>,
+    base_url: &str,
+) -> Result<bool> {
+    verify_github_file_attestations_inner(
+        file_path, owner, repo, token, signer_workflow, Some(base_url),
+    )
+    .await
+}
+
+async fn verify_github_file_attestations_inner(
+    file_path: &Path,
+    owner: &str,
+    repo: &str,
+    token: Option<&str>,
+    signer_workflow: Option<&str>,
+    api_url: Option<&str>,
+) -> Result<bool> {
+    let mut builder = AttestationClient::builder();
+    if let Some(token) = token {
+        builder = builder.github_token(token);
+    }
+    if let Some(api_url) = api_url {
+        builder = builder.base_url(api_url);
+    }
+    let client = builder.build()?;
+
+    // Step 1: Try archive-level verification first.
+    let archive_digest = calculate_file_digest_async(file_path).await?;
+    let archive_attestations = client
+        .fetch_attestations(FetchParams {
+            owner: owner.to_string(),
+            repo: Some(format!("{owner}/{repo}")),
+            digest: format!("sha256:{archive_digest}"),
+            limit: 30,
+            predicate_type: None,
+        })
+        .await?;
+
+    if !archive_attestations.is_empty() {
+        let artifact = tokio::fs::read(file_path).await?;
+        let mut trust_roots = TrustRoots::default();
+        let verified =
+            verify_attestation_bundles(&archive_attestations, &artifact, signer_workflow, &mut trust_roots)
+                .await;
+        match verified {
+            Ok(result) => return Ok(result),
+            Err(AttestationError::Sigstore(msg)) if msg.contains("No certificate found") => {
+                // This means the archive has attestations but they didn't verify
+                // for this archive's bytes. Don't fall through to per-file.
+                return Ok(false);
+            }
+            Err(e) => return Err(e),
+        }
+    }
+
+    // Step 2: No archive-level attestations. Extract and check per-file.
+    let tmp_dir = tempfile::tempdir()?;
+    let format = TarFormat::from_file_name(
+        file_path
+            .file_name()
+            .unwrap_or_default()
+            .to_string_lossy()
+            .as_ref(),
+    );
+    extract_archive(file_path, tmp_dir.path(), format)?;
+
+    // Collect all regular file paths. Skip symlinks, directories, and device files.
+    let mut files: Vec<_> = Vec::new();
+    collect_files(tmp_dir.path(), &mut files)?;
+
+    if files.is_empty() {
+        return Err(AttestationError::Io(std::io::Error::new(
+            std::io::ErrorKind::InvalidInput,
+            "archive extracted but contains no regular files",
+        )));
+    }
+
+    let mut errors = Vec::new();
+    let mut found_nothing = true;
+
+    for file_path in &files {
+        let digest = calculate_file_digest_async(file_path).await?;
+        let attestations = client
+            .fetch_attestations(FetchParams {
+                owner: owner.to_string(),
+                repo: Some(format!("{owner}/{repo}")),
+                digest: format!("sha256:{digest}"),
+                limit: 30,
+                predicate_type: None,
+            })
+            .await?;
+
+        if attestations.is_empty() {
+            // No attestations for this file — try the next one.
+            found_nothing = false;
+            continue;
+        }
+
+        found_nothing = false;
+        let file_bytes = tokio::fs::read(file_path).await?;
+        let mut trust_roots = TrustRoots::default();
+        match verify_attestation_bundles(
+            &attestations,
+            &file_bytes,
+            signer_workflow,
+            &mut trust_roots,
+        )
+        .await
+        {
+            Ok(result) => return Ok(result),
+            // Attestation exists but verification failed for this specific file.
+            // This is a HARD error — it means the file's signature was
+            // validated against a different digest, indicating tampering.
+            Err(AttestationError::Sigstore(msg))
+                if msg.contains("No certificate found")
+                    || msg.contains("digest does not match") =>
+            {
+                return Ok(false);
+            }
+            Err(e) => errors.push(e.to_string()),
+        }
+    }
+
+    // Extraction succeeded and we checked all files.
+    // - If no files had any attestations at all, it's "no attestations found".
+    // - If some files had attestations but verification failed for every one,
+    //   we already returned Ok(false) above in the loop (fail closed).
+    // Reach here → no attestations found for any file.
+    if found_nothing {
+        Err(AttestationError::NoAttestations)
+    } else {
+        // Some files had attestations but we couldn't parse/verify any of them.
+        Err(AttestationError::Verification(join_error_strings(
+            errors,
+            || "Per-file attestation verification failed for all files with attestations".to_string(),
+        )))
+    }
+}
+
+/// Extract an archive to `dest`, handling tar, tar.gz, tar.bz2, tar.xz, zip, and 7z formats.
+fn extract_archive(archive: &Path, dest: &Path, format: TarFormat) -> Result<()> {
+    match format {
+        TarFormat::Tar
+        | TarFormat::TarGz
+        | TarFormat::TarBz2
+        | TarFormat::TarXz
+        | TarFormat::TarZst
+        | TarFormat::Gz
+        | TarFormat::Xz
+        | TarFormat::Bz2
+        | TarFormat::Zst => {
+            let ar = open_tar(format, archive).map_err(|e| {
+                AttestationError::Io(std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!("failed to open archive: {e}"),
+                ))
+            })?;
+            let mut archive = tar::Archive::new(ar);
+            // Safety: only extract regular files (skip symlinks, directories, etc.)
+            // We only care about files that could contain binary content to verify.
+            archive.set_preserve_mtime(false);
+            archive
+                .unpack(dest)
+                .map_err(|e| AttestationError::Io(std::io::Error::new(std::io::ErrorKind::Other, e)))
+        }
+        TarFormat::Zip => {
+            let file = std::fs::File::open(archive).map_err(|e| {
+                AttestationError::Io(std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!("failed to open zip archive: {e}"),
+                ))
+            })?;
+            let mut archive = zip::ZipArchive::new(file).map_err(|e| {
+                AttestationError::Io(std::io::Error::new(
+                    std::io::ErrorKind::InvalidInput,
+                    format!("failed to parse zip archive: {e}"),
+                ))
+            })?;
+            archive
+                .extract(dest)
+                .map_err(|e| AttestationError::Io(std::io::Error::new(std::io::ErrorKind::Other, e)))
+        }
+        TarFormat::SevenZip => {
+            // 7z extraction not implemented in this crate
+            Err(AttestationError::UnsupportedFormat(
+                "7z archive format not supported for per-file attestation verification".to_string(),
+            ))
+        }
+        TarFormat::Raw => {
+            // No archive to extract — the "file" is the archive itself.
+            // Caller should have already checked archive-level verification.
+            Err(AttestationError::UnsupportedFormat(
+                "raw file has no archive structure to extract".to_string(),
+            ))
+        }
+    }
+}
+
+/// Recursively collect all regular file paths under `root`.
+fn collect_files(root: &Path, files: &mut Vec<std::path::PathBuf>) -> Result<()> {
+    if !root.is_dir() {
+        if root.is_file() {
+            files.push(root.to_path_buf());
+        }
+        return Ok(());
+    }
+    for entry in std::fs::read_dir(root).map_err(|e| {
+        AttestationError::Io(std::io::Error::new(std::io::ErrorKind::Other, e))
+    })? {
+        let entry = entry.map_err(|e| {
+            AttestationError::Io(std::io::Error::new(std::io::ErrorKind::Other, e))
+        })?;
+        let path = entry.path();
+        let file_type = entry.file_type().map_err(|e| {
+            AttestationError::Io(std::io::Error::new(std::io::ErrorKind::Other, e))
+        })?;
+        match file_type {
+            ft if ft.is_file() => {
+                files.push(path);
+            }
+            ft if ft.is_dir() => {
+                collect_files(&path, files)?;
+            }
+            _ => {
+                // Skip symlinks, block/char devices, sockets, pipes, etc.
+                // We only verify attestations for real files on disk.
+            }
+        }
+    }
+    Ok(())
+}
