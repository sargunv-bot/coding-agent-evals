---
import type { Run } from '../lib/types';
import { basePath, humanizeEnum, modelSlug, runHref } from '../lib/format';
const { runs, heading = 'Runs', id='runs-explorer', showTask=true, showModel=true } = Astro.props as {runs:Run[];heading?:string;id?:string;showTask?:boolean;showModel?:boolean};
const tasks=[...new Map(runs.map(r=>[r.taskId,r.taskTitle||r.taskId])).entries()]; const models=[...new Map(runs.map(r=>[modelSlug(r.provider,r.model),`${r.provider} / ${r.model}`])).entries()];
const result=(r:Run)=>r.deterministicPass===true?'pass':r.deterministicPass===false?'fail':'unavailable';
---
<section id={id} class="runs-explorer"><div class="utility-heading"><h2>{heading}</h2><strong data-run-count>{runs.length} runs</strong></div>
<form class="filter-bar" data-run-filters><label>Search<input type="search" name="q" placeholder="Task, model, scenario…"/></label><label>Task<select name="task"><option value="">All tasks</option>{tasks.map(([v,l])=><option value={v}>{l}</option>)}</select></label><label>Model / provider<select name="model"><option value="">All models</option>{models.map(([v,l])=><option value={v}>{l}</option>)}</select></label><label>Observed result<select name="result"><option value="">All results</option><option value="pass">Pass</option><option value="fail">Fail</option><option value="unavailable">Unavailable</option></select></label><label>Review<select name="review"><option value="">All review states</option><option value="reviewed">Reviewed</option><option value="pending">Pending</option><option value="not-ready">Not ready</option></select></label><details><summary>Advanced provenance</summary><label>Experiment<select name="experiment"><option value="">All experiments</option>{[...new Set(runs.map(r=>r.experimentId))].map(v=><option value={v}>{v}</option>)}</select></label></details><button type="reset">Reset</button></form>
<div class="run-table"><table><thead><tr>{showTask&&<th>Task</th>}{showModel&&<th>Model</th>}<th>Configuration</th><th>Observed checks</th><th>Review</th><th>Destination</th></tr></thead><tbody>{runs.map(r=><tr data-run data-task={r.taskId} data-model={modelSlug(r.provider,r.model)} data-result={result(r)} data-review={r.reviewState.kind} data-experiment={r.experimentId} data-search={`${r.taskTitle} ${r.taskId} ${r.provider} ${r.model} ${r.scenario} ${r.experimentId}`.toLowerCase()}>{showTask&&<td><a aria-label={`Task report: ${r.taskTitle}`} href={basePath(`tasks/${r.taskId}/`)}>{r.taskTitle}</a></td>}{showModel&&<td><a aria-label={`Model report: ${r.provider} / ${r.model}`} href={basePath(`models/${modelSlug(r.provider,r.model)}/`)}>{r.provider} / {r.model}</a></td>}<td>{humanizeEnum(r.scenario)}<small>{r.experimentId} · repeat {r.repeat}</small></td><td><span class={`result-pill ${result(r)==='pass'?'pass':result(r)==='fail'?'fail':'neutral'}`}>{r.observed.summary}</span></td><td>{r.reviewState.label}</td><td><a class="open-run" href={runHref(r)}>Open run</a></td></tr>)}</tbody></table></div>
<div class="run-cards">{runs.map(r=><article data-run data-task={r.taskId} data-model={modelSlug(r.provider,r.model)} data-result={result(r)} data-review={r.reviewState.kind} data-experiment={r.experimentId} data-search={`${r.taskTitle} ${r.provider} ${r.model} ${r.scenario} ${r.experimentId}`.toLowerCase()}><div class="card-top"><span class={`result-pill ${result(r)==='pass'?'pass':result(r)==='fail'?'fail':'neutral'}`}>{r.observed.summary}</span><span>{r.reviewState.label}</span></div>{showTask&&<h3><a href={basePath(`tasks/${r.taskId}/`)}>{r.taskTitle}</a></h3>}{showModel&&<p><a href={basePath(`models/${modelSlug(r.provider,r.model)}/`)}>{r.provider} / {r.model}</a></p>}<dl><div><dt>Configuration</dt><dd>{humanizeEnum(r.scenario)}</dd></div><div><dt>Provenance</dt><dd>{r.experimentId} · repeat {r.repeat}</dd></div></dl><a class="open-run" href={runHref(r)}>Open run</a></article>)}</div>
<p data-empty hidden>No runs match these filters.</p></section>
<script>
for(const root of document.querySelectorAll('.runs-explorer')){const form=root.querySelector('form');if(!(form instanceof HTMLFormElement))continue;const apply=()=>{const f=new FormData(form),q=String(f.get('q')||'').toLowerCase();let n=0;root.querySelectorAll('[data-run]').forEach(el=>{const ok=!q||String((el as HTMLElement).dataset.search).includes(q);const match=['task','model','result','review','experiment'].every(k=>!f.get(k)||(el as HTMLElement).dataset[k]===f.get(k));(el as HTMLElement).hidden=!(ok&&match);if(ok&&match)n++;});const count=root.querySelector('[data-run-count]');if(count)count.textContent=`${n/2} runs`;const empty=root.querySelector('[data-empty]') as HTMLElement;if(empty)empty.hidden=n>0;const url=new URL(location.href);for(const [k,v] of f){if(String(v))url.searchParams.set(k,String(v));else url.searchParams.delete(k)}history.replaceState({},'',url)};const params=new URLSearchParams(location.search);for(const el of form.elements){if(el instanceof HTMLInputElement||el instanceof HTMLSelectElement){const v=params.get(el.name);if(v!==null)el.value=v}}form.addEventListener('input',apply);form.addEventListener('reset',()=>setTimeout(apply));apply()}
</script>
