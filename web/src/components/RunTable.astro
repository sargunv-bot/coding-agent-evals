---
import type { Run } from '../lib/types';
import { basePath, humanizeEnum, modelSlug, runHref } from '../lib/format';
const { runs, caption = 'Runs', showTask = true } = Astro.props as { runs: Run[]; caption?: string; showTask?: boolean };
const deterministic = (run: Run) => run.deterministicPass === true ? 'Pass' : run.deterministicPass === false ? 'Fail' : 'Unavailable';
const columns = showTask ? 6 : 5;
---
<div class="table-wrap"><table class="table"><caption class="sr-only">{caption}</caption><thead><tr>{showTask && <th scope="col">Task</th>}<th scope="col">Provider / model</th><th scope="col">Configuration</th><th scope="col">Deterministic result</th><th scope="col">Subjective review</th><th scope="col"><span class="sr-only">Run details</span></th></tr></thead><tbody>
{runs.map((run) => <tr>{showTask && <td><a href={basePath(`tasks/${run.taskId}/`)}>{run.taskTitle || run.taskId}</a></td>}<td><a href={basePath(`models/${modelSlug(run.provider, run.model)}/`)}><span class="provider-prefix">{run.provider}</span> / {run.model}</a></td><td>{humanizeEnum(run.scenario)} · repeat {run.repeat}</td><td><span class={run.deterministicPass ? 'status-pass' : run.deterministicPass === false ? 'status-fail' : 'status-warn'}>{deterministic(run)}</span></td><td><span class={run.reviewState.kind === 'reviewed' ? 'badge badge-info' : run.reviewState.kind === 'pending' ? 'status-warn' : 'status-neutral'}>{run.reviewState.label}</span></td><td><a class="btn btn-sm btn-outline" href={runHref(run)}>Inspect</a></td></tr>)}
{runs.length === 0 && <tr><td colspan={columns}>No committed runs yet.</td></tr>}
</tbody></table></div>
