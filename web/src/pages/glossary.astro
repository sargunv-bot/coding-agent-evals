---
import BaseLayout from '../layouts/BaseLayout.astro';
import { glossary } from '../lib/glossary';
const id = (term: string) => term.toLowerCase().replace(/ mode$/, '').replace(/ tokens$/, '-tokens').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---
<BaseLayout title="Glossary">
  <p class="eyebrow">Plain-language reference</p><h1 class="text-4xl font-black">Glossary</h1><p class="prose-readable mt-3">Definitions for evaluation terms used throughout the site. Each term has a stable link.</p>
  <nav class="panel mt-7" aria-label="Glossary terms"><ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm">{glossary.map(([term]) => <li><a href={`#${id(term)}`}>{term}</a></li>)}</ul></nav>
  <dl class="mt-6 grid gap-3 lg:grid-cols-2">{glossary.map(([term, definition]) => <div id={id(term)} class="panel scroll-mt-24"><dt class="text-lg font-bold"><a class="no-underline" href={`#${id(term)}`} aria-label={`Permanent link to ${term}`}>{term}</a></dt><dd class="mt-1 text-base-content/75">{definition}</dd></div>)}</dl>
</BaseLayout>
