---
import BaseLayout from '../../layouts/BaseLayout.astro'; import RunsExplorer from '../../components/RunsExplorer.astro'; import {loadSiteData} from '../../lib/data'; import {humanizeEnum} from '../../lib/format';
export async function getStaticPaths(){const d=await loadSiteData();return d.tasks.map(task=>({params:{task:task.taskId},props:{task}}))} const {task}=Astro.props;
---
<BaseLayout title={task.title}><div class="page-title"><div><p class="utility-kicker">Task report · {task.taskId}</p><h1>{task.title}</h1><p>{task.description}</p></div><div class="identity-links">{task.repositoryUrl&&<a href={task.repositoryUrl}>Repository</a>}{task.upstreamPrimaryUrl&&<a href={task.upstreamPrimaryUrl}>Original change</a>}{task.upstreamOriginalDiscussionUrl&&<a href={task.upstreamOriginalDiscussionUrl}>Discussion</a>}</div></div><div class="summary-strip"><span>{new Set(task.runs.map(r=>`${r.provider}/${r.model}`)).size} models</span><span>{task.runs.length} runs</span><span>{task.runs.filter(r=>r.reviewState.kind==='reviewed').length} reviewed</span><span>{task.scenarios.map(humanizeEnum).join(', ')||'Default scenario'}</span></div><RunsExplorer runs={task.runs} heading="All task runs" showTask={false}/><details class="metadata-disclosure"><summary>Task source details</summary><dl><dt>Language</dt><dd>{task.language||'Unknown'}</dd><dt>Category</dt><dd>{task.category||'Unknown'}</dd>{task.upstreamBroaderContextUrl&&<><dt>Broader context</dt><dd><a href={task.upstreamBroaderContextUrl}>Open source context</a></dd></>}</dl></details></BaseLayout>
