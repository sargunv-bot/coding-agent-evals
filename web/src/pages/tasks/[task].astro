---
import BaseLayout from '../../layouts/BaseLayout.astro'; import RunTable from '../../components/RunTable.astro'; import Warnings from '../../components/Warnings.astro'; import { loadSiteData } from '../../lib/data';
export async function getStaticPaths() { const data = await loadSiteData(); return data.tasks.map((task) => ({ params: { task: task.taskId }, props: { task } })); }
const { task } = Astro.props; const compare = task.repositoryUrl && task.baseCommitHash && task.goldCommitHash ? `${task.repositoryUrl}/compare/${task.baseCommitHash}...${task.goldCommitHash}` : undefined;
---
<BaseLayout title={task.title} description={task.description}><p class="eyebrow">Task</p><h1 class="text-4xl font-black">{task.title}</h1><p class="prose-readable mt-3 text-lg">{task.description}</p><div class="mt-5 flex flex-wrap gap-2"><span class="badge badge-outline">{task.language}</span><span class="badge badge-outline">{task.category}</span>{task.scenarios.map((s) => <span class="badge badge-secondary">Scenario: {s}</span>)}</div>
<section class="panel mt-8"><h2 class="text-xl font-bold">Upstream source context</h2><p class="mt-1 text-sm text-base-content/70">Pinned source provenance used to construct the task; these links are context, not evaluation results.</p><dl class="mt-4 grid gap-3 sm:grid-cols-[12rem_1fr]"><dt class="font-semibold">Repository</dt><dd>{task.repositoryUrl ? <a href={task.repositoryUrl}>Upstream repository</a> : 'Unavailable'}</dd><dt class="font-semibold">Base commit</dt><dd><code class="break-all">{task.baseCommitHash || 'Unavailable'}</code></dd><dt class="font-semibold">Gold commit</dt><dd><code class="break-all">{task.goldCommitHash || 'Unavailable'}</code></dd><dt class="font-semibold">Base → gold compare</dt><dd>{compare ? <a href={compare}>View upstream comparison</a> : 'Unavailable'}</dd><dt class="font-semibold">Primary upstream change</dt><dd>{task.upstreamPrimaryUrl ? <a href={task.upstreamPrimaryUrl}>Open primary pull request</a> : 'Unavailable'}</dd>{task.upstreamBroaderContextUrl && <><dt class="font-semibold">Broader context</dt><dd><a href={task.upstreamBroaderContextUrl}>Open broader-context pull request</a></dd></>}{task.upstreamOriginalDiscussionUrl && <><dt class="font-semibold">Original discussion</dt><dd><a href={task.upstreamOriginalDiscussionUrl}>Open original source discussion</a></dd></>}</dl></section>
<Warnings warnings={task.runs.flatMap((r) => r.warnings)}/><section class="mt-10"><h2 class="mb-4 text-2xl font-bold">Runs</h2><RunTable runs={task.runs} caption={`Runs for ${task.title}`} showTask={false}/></section></BaseLayout>
