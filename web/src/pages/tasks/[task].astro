---
import BaseLayout from '../../layouts/BaseLayout.astro'; import RunsExplorer from '../../components/RunsExplorer.astro'; import {loadSiteData} from '../../lib/data'; import {humanizeEnum} from '../../lib/format';
export async function getStaticPaths(){const d=await loadSiteData();return d.tasks.map(task=>({params:{task:task.taskId},props:{task}}))} const {task}=Astro.props; const runs=task.runs.filter((r:any)=>r.authoritative); const scenarios=[...new Set(runs.map((r:any)=>r.scenario).filter(Boolean))];
---
<BaseLayout title={task.title}><div class="page-title"><div><p class="utility-kicker">Authoritative task report · {task.taskId}</p><h1>{task.title}</h1><p>{task.description}</p></div><div class="identity-links">{task.repositoryUrl&&<a href={task.repositoryUrl}>Repository</a>}{task.upstreamPrimaryUrl&&<a href={task.upstreamPrimaryUrl}>Original change</a>}{task.upstreamOriginalDiscussionUrl&&<a href={task.upstreamOriginalDiscussionUrl}>Discussion</a>}</div></div><div class="summary-strip"><span>{new Set(runs.map((r:any)=>`${r.provider}/${r.model}`)).size} models</span><span>{runs.length} runs</span><span>{runs.filter((r:any)=>r.reviewState.kind==='reviewed').length} reviewed</span><span>{scenarios.map((s:any)=>humanizeEnum(s)).join(', ')||'Unified/default scenario'}</span></div><RunsExplorer runs={runs} heading="Authoritative task runs" showTask={false}/><details class="metadata-disclosure"><summary>Task source details</summary><dl><dt>Language</dt><dd>{task.language||'Unknown'}</dd><dt>Category</dt><dd>{task.category||'Unknown'}</dd>{task.upstreamBroaderContextUrl&&<><dt>Broader context</dt><dd><a href={task.upstreamBroaderContextUrl}>Open source context</a></dd></>}</dl></details></BaseLayout>
