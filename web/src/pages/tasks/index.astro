---
import BaseLayout from '../../layouts/BaseLayout.astro'; import {loadSiteData} from '../../lib/data'; import {basePath} from '../../lib/format'; const data=await loadSiteData(); const tasks=data.tasks.map(t=>({...t,runs:t.runs.filter(r=>r.authoritative)})).filter(t=>t.runs.length);
---
<BaseLayout title="Tasks"><div class="page-title"><div><h1>Tasks</h1><p>{tasks.length} authoritative tasks</p></div></div><div class="dense-table"><table><thead><tr><th>Task</th><th>Repository / language</th><th>Models</th><th>Runs</th><th>Observed verification</th><th>Destination</th></tr></thead><tbody>{tasks.map(t=><tr><td><strong>{t.title}</strong><small>{t.taskId}</small></td><td>{t.repositoryUrl?<a href={t.repositoryUrl}>Repository</a>:'Unavailable'} · {t.language||'Unknown'}</td><td>{new Set(t.runs.map(r=>`${r.provider}/${r.model}`)).size}</td><td>{t.runs.length}</td><td>{[...new Set(t.runs.map(r=>r.observed.summary))].slice(0,3).join(' · ')||'No runs'}</td><td><a class="open-run" href={basePath(`tasks/${t.taskId}/`)}>Task report</a></td></tr>)}</tbody></table></div></BaseLayout>
