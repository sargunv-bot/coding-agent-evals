---
import BaseLayout from '../../../layouts/BaseLayout.astro'; import RunHeader from '../../../components/RunHeader.astro'; import {loadSiteData} from '../../../lib/data'; import {duration,number} from '../../../lib/format'; import {patchFileSummary,splitPatchByFile} from '../../../components/PatchViewer';
export async function getStaticPaths(){const d=await loadSiteData();return d.runs.map(run=>({params:{experiment:run.experimentId,cell:run.cellId},props:{run}}))} const {run}=Astro.props; const files=run.patch?splitPatchByFile(run.patch).map(patchFileSummary):[];const additions=files.reduce((n,f)=>n+f.additions,0),deletions=files.reduce((n,f)=>n+f.deletions,0);const tools=run.transcript.filter((e:any)=>e.tool).length,reasoning=run.transcript.filter((e:any)=>e.type==='reasoning').length,errors=run.transcript.filter((e:any)=>e.error!==undefined||e.status==='error').length;
---
<BaseLayout title={`${run.taskTitle} · ${run.model}`}><RunHeader run={run} active="Summary"/><section class="run-content"><div class="summary-grid"><div><span>Observed checks</span><strong>{run.observed.summary}</strong></div><div><span>Duration</span><strong>{duration(run.durationSeconds)}</strong></div><div><span>Patch</span><strong>{files.length} files · +{additions}/−{deletions}</strong></div><div><span>Transcript</span><strong>{tools} tools · {reasoning} reasoning · {errors} errors</strong></div></div><section class="content-section"><h2>Usage</h2><dl class="inline-stats"><div><dt>Input</dt><dd>{number(run.tokens.input)}</dd></div><div><dt>Cached</dt><dd>{number(run.tokens.cachedInput)}</dd></div><div><dt>Output</dt><dd>{number(run.tokens.output)}</dd></div><div><dt>Reasoning tokens</dt><dd>{number(run.tokens.reasoning)}</dd></div></dl></section><section class="content-section"><h2>Qualitative review <small>non-authoritative</small></h2><p><strong>{run.reviewState.label}</strong> · {run.reviewState.explanation}</p>{run.reviewState.review&&<p>{String((run.reviewState.review as any).summary||(run.reviewState.review as any).overall_reasoning||'Review data available on this run.')}</p>}</section></section></BaseLayout>
