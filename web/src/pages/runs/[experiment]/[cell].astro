---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Warnings from '../../../components/Warnings.astro';
import { PatchViewer } from '../../../components/PatchViewer';
import { TranscriptViewer } from '../../../components/TranscriptViewer';
import { loadSiteData } from '../../../lib/data';
import { basePath, humanizeEnum, number } from '../../../lib/format';
export async function getStaticPaths() { const data = await loadSiteData(); return data.runs.map((run) => ({ params: { experiment: run.experimentId, cell: run.cellId }, props: { run } })); }
const { run } = Astro.props;
const patchArtifact = run.artifacts.find((artifact) => artifact.path === 'model.patch');
const transcriptArtifact = run.artifacts.find((artifact) => artifact.path === 'transcript.jsonl');
const instructionArtifact = run.artifacts.find((artifact) => artifact.path === 'instruction.txt');
const review = run.reviewState.review || {};
const resultLabel = run.infrastructureError ? 'Infrastructure error' : run.deterministicPass === true ? 'Pass' : run.deterministicPass === false ? 'Fail' : 'Unavailable';
const duration = (seconds?: number) => !seconds ? '—' : seconds >= 3600 ? `${Math.floor(seconds / 3600)}h ${Math.floor(seconds % 3600 / 60)}m` : seconds >= 60 ? `${Math.floor(seconds / 60)}m ${Math.round(seconds % 60)}s` : `${seconds.toFixed(1)}s`;
---
<BaseLayout title={`${run.taskTitle || run.taskId} · ${run.model}`}>
  <nav class="breadcrumbs text-sm" aria-label="Breadcrumb"><ul><li><a href={basePath('tasks/')}>Tasks</a></li><li><a href={basePath(`tasks/${run.taskId}/`)}>{run.taskTitle || run.taskId}</a></li><li>Run</li></ul></nav>
  <header class="mt-6"><p class="eyebrow">Run · one model attempt</p><h1 class="mt-2 text-3xl font-black sm:text-4xl">{run.provider} / {run.model}</h1><p class="mt-2 text-lg"><a href={basePath(`tasks/${run.taskId}/`)}>{run.taskTitle || run.taskId}</a></p><div class="mt-4 flex flex-wrap gap-2"><span class="badge badge-outline">{humanizeEnum(run.mode)} mode</span>{run.scenario && <span class="badge badge-outline">Scenario: {humanizeEnum(run.scenario)}</span>}<span class="badge badge-outline">Repeat {run.repeat}</span>{instructionArtifact && <a class="badge badge-outline" href={instructionArtifact.url}>Task prompt</a>}</div></header>

  <div class="mt-7 grid gap-3 sm:grid-cols-2 lg:grid-cols-4"><div class="metric"><div class="stat-title">Deterministic result</div><div class:list={['stat-value text-2xl', run.deterministicPass ? 'text-success' : run.deterministicPass === false ? 'text-error' : 'text-warning']}>{resultLabel}</div><div class="stat-desc">{run.verificationOutcome || 'No verifier outcome yet'}</div></div><div class="metric"><div class="stat-title">Run state</div><div class="stat-value text-2xl">{humanizeEnum(run.state)}</div><div class="stat-desc">Evidence publication state</div></div><div class="metric"><div class="stat-title">Mode</div><div class="stat-value text-lg">{humanizeEnum(run.mode)}</div><div class="stat-desc"><a href={basePath(`glossary/#${run.mode.replaceAll('_','-')}`)}>What does this mean?</a></div></div><div class="metric"><div class="stat-title">Duration</div><div class="stat-value text-2xl">{duration(run.durationSeconds)}</div><div class="stat-desc">Candidate runtime</div></div></div>

  <details class="technical-metadata mt-4"><summary>Technical identifiers and experiment provenance</summary><dl class="mt-3 grid gap-2 sm:grid-cols-[9rem_1fr]"><dt>Run ID</dt><dd><code class="break-all">{run.runId || 'Not assigned'}</code></dd><dt>Cell ID</dt><dd><code class="break-all">{run.cellId}</code></dd><dt>Experiment</dt><dd><code>{run.experimentId}</code></dd></dl></details>
  <section class="panel mt-6"><h2 class="text-xl font-bold">What this run means</h2><p class="mt-2">This is one attempt by the provider/model above at <a href={basePath(`tasks/${run.taskId}/`)}>the same pinned task</a>. The deterministic verifier decides pass or fail. Mode, scenario, and repeat describe the configuration; the experiment name is retained only as provenance.</p></section>
  <Warnings warnings={run.warnings}/>

  <section class="mt-10"><h2 class="text-2xl font-bold">Token usage</h2><p class="mt-1 text-sm text-base-content/70">Provider-reported counts; definitions are in the <a href={basePath('glossary/')}>glossary</a>.</p><div class="mt-4 grid grid-cols-2 gap-3 lg:grid-cols-4"><div class="metric"><div class="stat-title">Input</div><div class="stat-value text-2xl">{number(run.tokens.input)}</div></div><div class="metric"><div class="stat-title">Cached input</div><div class="stat-value text-2xl">{number(run.tokens.cachedInput)}</div></div><div class="metric"><div class="stat-title">Output</div><div class="stat-value text-2xl">{number(run.tokens.output)}</div></div><div class="metric"><div class="stat-title">Reasoning</div><div class="stat-value text-2xl">{number(run.tokens.reasoning)}</div></div></div></section>

  <section class="panel mt-10"><h2 class="text-2xl font-bold">Subjective review</h2><div class="mt-3"><span class:list={['badge', run.reviewState.kind === 'reviewed' ? 'badge-info' : run.reviewState.kind === 'pending' ? 'badge-warning' : 'badge-ghost']}>{run.reviewState.label}</span></div><p class="mt-3 font-medium">{run.reviewState.explanation}</p>{run.reviewState.kind === 'reviewed' && <div class="mt-5 space-y-4"><p>{review.summary || review.overall_reasoning || 'No summary supplied.'}</p><div class="flex flex-wrap gap-2">{['code_clarity','repository_fit','scope_discipline','security_and_safety','test_quality'].map((key) => review[key] !== undefined && <span class="badge badge-outline">{humanizeEnum(key)}: {String(review[key])}</span>)}</div>{review.overall_reasoning && <div><h3 class="font-bold">Rationale</h3><p>{String(review.overall_reasoning)}</p></div>}<details><summary>Complete review JSON</summary><pre class="mt-3">{JSON.stringify(review, null, 2)}</pre></details></div>}<div class="review-boundary mt-5"><strong>Non-overriding:</strong> this assessment cannot change the deterministic result shown above.</div></section>

  {run.verifierOutput && <section class="panel mt-10"><div class="section-heading"><div><p class="eyebrow">Authoritative evidence</p><h2 class="text-xl font-bold">Verifier output</h2></div></div><pre class="verifier-output mt-3">{run.verifierOutput}</pre></section>}
  {run.patch && <section class="panel mt-10"><PatchViewer patch={run.patch} rawUrl={patchArtifact?.url} sha256={patchArtifact?.sha256} client:load /><noscript>{patchArtifact && <p><a href={patchArtifact.url}>Download the raw candidate patch</a>; the interactive diff viewer requires JavaScript.</p>}</noscript></section>}
  {run.state === 'completed' && <section class="mt-10"><TranscriptViewer events={run.transcript} truncated={run.transcriptTruncated} warnings={run.transcriptWarnings} rawUrl={transcriptArtifact?.url}/></section>}

  <section class="mt-10"><h2 class="mb-4 text-2xl font-bold">Committed evidence</h2><div class="evidence-list">{run.artifacts.map((artifact) => <article class="evidence-item"><div><a class="font-semibold" href={artifact.url} download>{artifact.path}</a><p class="text-sm text-base-content/65">{number(artifact.bytes)} bytes</p></div><div class="evidence-status">{artifact.hashMatches ? <span class="status-pass">Hash matches</span> : <span class="status-fail">Hash mismatch</span>}<details class="mt-2 text-sm"><summary>SHA-256</summary><code class="mt-2 block break-all">{artifact.sha256}</code></details></div></article>)}</div></section>
</BaseLayout>
