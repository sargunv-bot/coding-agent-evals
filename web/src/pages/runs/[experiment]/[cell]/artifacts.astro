---
import BaseLayout from '../../../../layouts/BaseLayout.astro'; import RunHeader from '../../../../components/RunHeader.astro'; import {loadSiteData} from '../../../../lib/data'; import {number} from '../../../../lib/format';
export async function getStaticPaths(){const d=await loadSiteData();return d.runs.map(run=>({params:{experiment:run.experimentId,cell:run.cellId},props:{run}}))} const {run}=Astro.props;
---
<BaseLayout title={`Artifacts · ${run.taskTitle}`}><RunHeader run={run} active="Artifacts"/><section class="run-content"><div class="artifact-list">{run.artifacts.map((a:any)=><article><div><strong>{a.path}</strong><span>{number(a.bytes)} bytes</span></div><a class="open-run" href={a.url} download>Download</a></article>)}</div><details class="integrity"><summary>Integrity details</summary><p>These values compare the committed artifacts manifest with SHA-256 recomputed during the site build.</p><div class="integrity-table">{run.artifacts.map((a:any)=><div><strong>{a.path}</strong><dl><dt>Manifest SHA</dt><dd><code>{a.expectedSha256||'Not supplied'}</code></dd><dt>Recomputed SHA</dt><dd><code>{a.sha256}</code></dd><dt>Match</dt><dd>{a.hashMatches===false?'Mismatch':'Match'}</dd></dl></div>)}</div><dl><dt>Run ID</dt><dd><code>{run.runId||'Not assigned'}</code></dd><dt>Cell ID</dt><dd><code>{run.cellId}</code></dd><dt>Experiment</dt><dd><code>{run.experimentId}</code></dd></dl></details></section></BaseLayout>
