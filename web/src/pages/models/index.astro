---
import BaseLayout from '../../layouts/BaseLayout.astro'; import {loadSiteData} from '../../lib/data'; import {basePath} from '../../lib/format'; const data=await loadSiteData(); const models=data.models.map(m=>({...m,runs:m.runs.filter(r=>r.authoritative)})).filter(m=>m.runs.length); const taskCount=new Set(data.authoritativeRuns.map(r=>r.taskId)).size;
---
<BaseLayout title="Models"><div class="page-title"><div><h1>Models</h1><p>{models.length} authoritative provider/model identities</p></div></div><div class="dense-table"><table><thead><tr><th>Provider / model</th><th>Task coverage</th><th>Runs</th><th>Observed checks</th><th>Review coverage</th><th>Destination</th></tr></thead><tbody>{models.map(m=><tr><td><strong>{m.name}</strong><small>{m.provider}</small></td><td>{new Set(m.runs.map(r=>r.taskId)).size}/{taskCount}</td><td>{m.runs.length}</td><td>{[...new Set(m.runs.map(r=>r.observed.summary))].slice(0,3).join(' · ')}</td><td>{m.runs.filter(r=>r.reviewState.kind==='reviewed').length}/{m.runs.length}</td><td><a class="open-run" href={basePath(`models/${m.slug}/`)}>Model report</a></td></tr>)}</tbody></table></div></BaseLayout>
