---
import BaseLayout from '../../layouts/BaseLayout.astro'; import RunTable from '../../components/RunTable.astro'; import { loadSiteData } from '../../lib/data';
export async function getStaticPaths() { const data = await loadSiteData(); return data.models.map((model) => ({ params: { model: model.slug }, props: { model } })); }
const { model } = Astro.props;
---
<BaseLayout title={model.name}><p class="eyebrow">Model</p><h1 class="text-4xl font-black">{model.name}</h1><p class="mt-3"><strong>Provider:</strong> {model.provider}. A provider is the service or endpoint that supplied access to this model.</p><section class="mt-10"><h2 class="mb-4 text-2xl font-bold">Runs by task</h2><RunTable runs={model.runs} caption={`Runs for ${model.key}`}/></section></BaseLayout>
