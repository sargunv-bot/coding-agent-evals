---
import BaseLayout from '../../layouts/BaseLayout.astro'; import RunsExplorer from '../../components/RunsExplorer.astro'; import {loadSiteData} from '../../lib/data';
export async function getStaticPaths(){const d=await loadSiteData();return d.models.map(model=>({params:{model:model.slug},props:{model}}))} const {model}=Astro.props; const authoritative=model.runs.filter((r:any)=>r.authoritative); const runs=authoritative.length?authoritative:model.runs; const tasks=new Set(runs.map((r:any)=>r.taskId)).size;
---
<BaseLayout title={model.name}><div class="page-title"><div><p class="utility-kicker">{authoritative.length?'Authoritative model report':'Historical model report'} · {model.provider}</p><h1>{model.name}</h1></div></div><div class="summary-strip"><span>{tasks} tasks covered</span><span>{runs.length} runs</span><span>{runs.filter((r:any)=>r.reviewState.kind==='reviewed').length}/{runs.length} reviewed</span><span>{runs.filter((r:any)=>r.infrastructureError).length} infrastructure errors</span></div><RunsExplorer runs={runs} heading="Runs by task" showModel={false}/></BaseLayout>
