---
import '../styles/global.css'; import {basePath} from '../lib/format'; interface Props{title:string;description?:string} const {title,description='Coding-agent evaluation reports.'}=Astro.props; const path=Astro.url.pathname; const links=[['Results',basePath()],['Runs',basePath('runs/')],['Tasks',basePath('tasks/')],['Models',basePath('models/')]];
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="description" content={description}/><title>{title} · Coding agent evaluations</title></head><body><a class="skip-link" href="#main">Skip to content</a><header class="site-header"><nav class="shell global-nav" aria-label="Global navigation"><a class="brand" href={basePath()}>Coding agent evals</a><div>{links.map(([label,href])=><a aria-current={(href===basePath()?path===href:path.startsWith(href))?'page':undefined} href={href}>{label}</a>)}<a href="https://github.com/sargunv/coding-agent-evals">Repository</a></div></nav></header><main id="main" class="shell"><slot/></main><footer><div class="shell"><span>Static committed evidence</span><a href={basePath('notices/')}>Notices</a></div></footer></body></html>
